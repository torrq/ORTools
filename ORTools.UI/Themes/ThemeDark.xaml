<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="AppBaseBrush" Color="#1E1E1E" />
    <SolidColorBrush x:Key="AppSurfaceBrush" Color="#252525" />
    <LinearGradientBrush x:Key="AppHeaderBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#161E10" Offset="0.0" />
        <GradientStop Color="#2B3D1F" Offset="1.0" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="AppSurfaceAltBrush" Color="#111111" />
    <SolidColorBrush x:Key="AppPanelBrush" Color="#181818" />
    <SolidColorBrush x:Key="AppTextBrush" Color="#E0E0E0" />
    <SolidColorBrush x:Key="AppMutedBrush" Color="#606060" />
    <SolidColorBrush x:Key="AppSubtleBrush" Color="#808080" />
    <SolidColorBrush x:Key="AppJobNameBrush" Color="#B0B0B0" />
    <SolidColorBrush x:Key="AppBorderBrush" Color="#2A2A2A" />
    <SolidColorBrush x:Key="AppInputBrush" Color="#2A2A2A" />
    <SolidColorBrush x:Key="AppInputBorderBrush" Color="#3A3A3A" />
    <SolidColorBrush x:Key="AppPrimaryBrush" Color="#585858" />
    <SolidColorBrush x:Key="AppPrimaryHoverBrush" Color="#474747" />
    <SolidColorBrush x:Key="AppPrimaryPressedBrush" Color="#333333" />
    <SolidColorBrush x:Key="AppLinkBrush" Color="#8BB54C" />
    <SolidColorBrush x:Key="AppToggleOnBrush" Color="#4F6B28" />
    <SolidColorBrush x:Key="AppToggleOnHoverBrush" Color="#3D521F" />
    <SolidColorBrush x:Key="AppToggleOffBrush" Color="#DC2828" />
    <SolidColorBrush x:Key="AppToggleOffHoverBrush" Color="#B91C1C" />
    <SolidColorBrush x:Key="AppDangerBrush" Color="#EF4444" />
    <SolidColorBrush x:Key="AppDangerHoverBrush" Color="#D73A3D" />
    <SolidColorBrush x:Key="AppSuccessBrush" Color="#4CAF50" />
    <SolidColorBrush x:Key="AppWarningBrush" Color="#FF9800" />
    <SolidColorBrush x:Key="AppInfoBrush" Color="#2196F3" />
    <SolidColorBrush x:Key="AppMapNameBrush" Color="#ADFF04" />
    <SolidColorBrush x:Key="AppWeightBrush" Color="#CD7F32" />

    <SolidColorBrush x:Key="AppProgressBarBackgroundBrush" Color="#40000000" />
    <SolidColorBrush x:Key="AppProgressBarTextBrush" Color="#FFFFFF" />
    <Color x:Key="AppProgressBarTextShadowColor">Black</Color>

    <SolidColorBrush x:Key="AppHpBorderBrush" Color="#14A014" />
    <SolidColorBrush x:Key="AppSpBorderBrush" Color="#0066FF" />
    <SolidColorBrush x:Key="AppWtBorderBrush" Color="#962D1E" />

    <Color x:Key="AppHpGlowColor">#14A014</Color>
    <Color x:Key="AppSpGlowColor">#0066FF</Color>
    <Color x:Key="AppWtGlowColor">#962D1E</Color>

    <LinearGradientBrush x:Key="AppHpNormalBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#50FF50" Offset="0.0" />
        <GradientStop Color="#14A014" Offset="1.0" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AppHpLowBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF5050" Offset="0.0" />
        <GradientStop Color="#C81E1E" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AppSpNormalBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#33CCFF" Offset="0.0" />
        <GradientStop Color="#0066FF" Offset="1.0" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AppSpLowBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFB432" Offset="0.0" />
        <GradientStop Color="#D26E00" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AppWtNormalBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#D26450" Offset="0.0" />
        <GradientStop Color="#962D1E" Offset="1.0" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="AppPrimaryTextBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="AppTabInactiveTextBrush" Color="#A0A0A0" />
    <SolidColorBrush x:Key="AppTabInactiveBrush" Color="Transparent" />
    <SolidColorBrush x:Key="AppTabInactiveBorderBrush" Color="#333333" />

    <BitmapImage x:Key="SpammerShiftIcon" UriSource="pack://application:,,,/Icons/Spammer/shift_white.png" />
    <BitmapImage x:Key="SpammerMouseIcon" UriSource="pack://application:,,,/Icons/Spammer/up_and_down_arrow_white.png" />
</ResourceDictionary>
