<Window x:Class="ORTools.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ORTools.UI.ViewModels"
        xmlns:views="clr-namespace:ORTools.UI.Views"
        xmlns:helpers="clr-namespace:ORTools.UI.Helpers"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="{Binding AppTitle}"
        Width="731"
        Height="675"
        MinWidth="600"
        MinHeight="500"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        FontFamily="Segoe UI" Background="{DynamicResource AppBaseBrush}">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:TimePickerViewModel}">
            <views:TimePickerView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:InputDialogViewModel}">
            <views:InputDialogView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ConfirmDeleteDialogViewModel}">
            <views:ConfirmDeleteDialogView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AlertDialogViewModel}">
            <views:AlertDialogView />
        </DataTemplate>
        <helpers:SpPercentToBrushConverter x:Key="SpPercentToBrushConverter" />
        <helpers:HpPercentToBrushConverter x:Key="HpPercentToBrushConverter" />
    </Window.Resources>
    <Window.Style>
        <Style TargetType="Window">
            <Setter Property="ResizeMode" Value="CanMinimize"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Settings.AllowResizingWindow}" Value="True">
                    <Setter Property="ResizeMode" Value="CanResize"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Style>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="171*"/>
            <ColumnDefinition Width="649*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <tb:TaskbarIcon x:Name="AppTrayIcon"
                        IconSource="{Binding TrayIconSource}"
                        ToolTipText="{Binding AppTitle}"
                        DoubleClickCommand="{Binding ShowWindowCommand}">
            <tb:TaskbarIcon.Style>
                <Style TargetType="tb:TaskbarIcon">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Settings.DisableSystray}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </tb:TaskbarIcon.Style>
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="{Binding ToggleButtonText}" Command="{Binding ToggleApplicationCommand}" />
                    <MenuItem Header="Profiles" ItemsSource="{Binding ProfileList}">
                        <MenuItem.ItemContainerStyle>
                            <Style TargetType="MenuItem">
                                <Setter Property="Header" Value="{Binding}" />
                                <Setter Property="Command" Value="{Binding DataContext.SelectProfileCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                <Setter Property="CommandParameter" Value="{Binding}" />
                                <Setter Property="IsCheckable" Value="True" />
                                <Setter Property="IsChecked">
                                    <Setter.Value>
                                        <MultiBinding Converter="{StaticResource EqualityMultiConverter}">
                                            <Binding Path="." />
                                            <Binding Path="DataContext.CurrentProfile" RelativeSource="{RelativeSource AncestorType=ContextMenu}" />
                                        </MultiBinding>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </MenuItem.ItemContainerStyle>
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="Exit" Command="{Binding ExitAppCommand}" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
        <Border x:Name="HeaderPanel" VerticalAlignment="Top" 
            Padding="10,8" Background="{DynamicResource AppHeaderBrush}" Grid.ColumnSpan="2">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDialogVisible}" Value="True">
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <BlurEffect Radius="8" KernelType="Gaussian" RenderingBias="Performance"/>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="70" />
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0"
                    VerticalAlignment="Center"
                    Margin="0,0,16,0" Height="0"/>

                <Image Width="96" Source="{Binding AppLogoSource}" HorizontalAlignment="Left" Grid.ColumnSpan="2">
                    <Image.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.5" />
                    </Image.Effect>
                </Image>

                <StackPanel Grid.Column="1"
                    VerticalAlignment="Center" Margin="40,0,0,0" Grid.IsSharedSizeScope="True">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="28" SharedSizeGroup="LabelCol" />
                            <ColumnDefinition Width="Auto" SharedSizeGroup="TextCol" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <Grid>
                                <TextBlock Text="{Binding CharacterName}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource AppTextBrush}" HorizontalAlignment="Left">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="{DynamicResource AppProgressBarTextShadowColor}" BlurRadius="1" ShadowDepth="1" Opacity="0.8" />
                                    </TextBlock.Effect>
                                </TextBlock>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,1">
                                    <TextBlock Text="{Binding InfoExpPerHourText}" FontSize="11" FontWeight="Normal" Foreground="{DynamicResource AppSuccessBrush}" VerticalAlignment="Bottom" Margin="0,0,8,0" Visibility="{Binding Settings.ShowExpPerHour, Converter={StaticResource BooleanToVisibilityConverter}}" Cursor="Hand" ToolTip="{Binding InfoExpPerHourTooltip}">
                                        <TextBlock.InputBindings>
                                            <MouseBinding Gesture="LeftClick" Command="{Binding ResetExpTrackerCommand}" />
                                        </TextBlock.InputBindings>
                                    </TextBlock>
                                    <Border Background="{DynamicResource AppInputBrush}" 
                                            BorderBrush="{DynamicResource AppInputBorderBrush}" 
                                            BorderThickness="1" CornerRadius="4" 
                                            Padding="4,0" Height="18"
                                            Visibility="{Binding IsMiniTimerVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                                            ToolTip="Auto Off Timer">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock FontFamily="pack://application:,,,/Fonts/#lucide" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center" Foreground="{DynamicResource AppSubtleBrush}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="&#xE087;"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsMiniTimerPaused}" Value="True">
                                                                <Setter Property="Text" Value="&#xE12E;"/>
                                                                <Setter Property="Foreground" Value="{DynamicResource AppPrimaryBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding MiniTimerText}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource AppTextBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,1,0,0">
                                <TextBlock x:Name="JobNameTextBlock" Text="{Binding JobName}"
                                           FontSize="11" FontWeight="Bold" Foreground="{DynamicResource AppJobNameBrush}"
                                           HorizontalAlignment="Left">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="{DynamicResource AppProgressBarTextShadowColor}" BlurRadius="1" ShadowDepth="1" Opacity="0.8" />
                                    </TextBlock.Effect>
                                </TextBlock>
                            </Grid>
                            <Grid Margin="0,3,0,0">
                                <TextBlock FontSize="11" HorizontalAlignment="Left"><Run Text="{Binding InfoLvLabel1Text}" Foreground="{DynamicResource AppSubtleBrush}" /><Run Text="{Binding InfoLvValue1Text}" Foreground="{DynamicResource AppTextBrush}" /><Run Text="{Binding InfoSeparator1Text}" Foreground="{DynamicResource AppSubtleBrush}" /><Run Text="{Binding InfoLvLabel2Text}" Foreground="{DynamicResource AppSubtleBrush}" /><Run Text="{Binding InfoLvValue2Text}" Foreground="{DynamicResource AppTextBrush}" /><Run Text="{Binding InfoSeparator2Text}" Foreground="{DynamicResource AppSubtleBrush}" /><Run Text="{Binding InfoExpLabelText}" Foreground="{DynamicResource AppSubtleBrush}" /><Run Text="{Binding InfoExpValueText}" Foreground="{DynamicResource AppTextBrush}" /></TextBlock>
                                <TextBlock x:Name="MapNameTextBlock" Text="{Binding MapName}" 
                                           FontSize="11" FontWeight="Bold" Foreground="{DynamicResource AppMapNameBrush}" 
                                           HorizontalAlignment="Right">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="{DynamicResource AppProgressBarTextShadowColor}" BlurRadius="1" ShadowDepth="1" Opacity="0.8" />
                                    </TextBlock.Effect>
                                </TextBlock>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Grid.ColumnSpan="2" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="6,0,0,0">
                            <Button x:Name="ToggleApplicationButton" Content="{Binding ToggleButtonText}"
                                    Command="{Binding ToggleApplicationCommand}"
                                    IsEnabled="{Binding IsClientConnected}"
                                    Style="{StaticResource ToggleApplicationButtonStyle}"
                                    Height="24" Width="100" FontSize="11" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="{DynamicResource S.Main.Key}" FontSize="10" Foreground="{DynamicResource AppSubtleBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBox x:Name="ToggleKeyTextBox" Text="{Binding ToggleKey, Mode=TwoWay, Converter={StaticResource KeyToStringConverter}}"
                                         PreviewKeyDown="ToggleKeyTextBox_PreviewKeyDown"
                                         Width="50" Height="22" MaxLength="10" FontSize="11"
                                         Style="{StaticResource KeyTextBoxStyle}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,4,0,0">
                        <ProgressBar x:Name="HpProgressBar" Value="{Binding HpPercent}"
                         Minimum="0" Maximum="100" Height="18" Background="{DynamicResource AppProgressBarBackgroundBrush}"
                         Foreground="{Binding HpPercent, Converter={StaticResource HpPercentToBrushConverter}}"
                         BorderBrush="{DynamicResource AppHpBorderBrush}" BorderThickness="1">
                            <ProgressBar.Effect>
                                <DropShadowEffect Color="{DynamicResource AppHpGlowColor}" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                            </ProgressBar.Effect>
                        </ProgressBar>
                        <TextBlock x:Name="HpTextBlock" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,3">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HpCurrentText}" Value="">
                                            <Setter Property="Visibility" Value="Hidden" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <TextBlock.Effect>
                                <DropShadowEffect Color="{DynamicResource AppProgressBarTextShadowColor}" BlurRadius="1" ShadowDepth="1" Opacity="0.8"/>
                            </TextBlock.Effect>
                            <Run Text="HP " Foreground="{DynamicResource AppProgressBarTextBrush}" />
                            <Run Text="{Binding HpCurrentText}" Foreground="{DynamicResource AppProgressBarTextBrush}" />
                            <Run Text=" / " Foreground="{DynamicResource AppProgressBarTextBrush}" />
                            <Run Text="{Binding HpMaxText}" Foreground="{DynamicResource AppProgressBarTextBrush}" />
                            <Run Text=" (" Foreground="{DynamicResource AppProgressBarTextBrush}" />
                            <Run Text="{Binding HpPercent, StringFormat={}{0:0}%}" Foreground="{DynamicResource AppProgressBarTextBrush}" />
                            <Run Text=")" Foreground="{DynamicResource AppProgressBarTextBrush}" />
                        </TextBlock>
                    </Grid>
                    
                    <Grid Margin="0,-1,0,0">
                        <ProgressBar x:Name="SpProgressBar" Value="{Binding SpPercent}"
                         Minimum="0" Maximum="100" Height="18" Background="{DynamicResource AppProgressBarBackgroundBrush}"
                         Foreground="{Binding SpPercent, Converter={StaticResource SpPercentToBrushConverter}}"
                         BorderBrush="{DynamicResource AppSpBorderBrush}" BorderThickness="1">
                            <ProgressBar.Effect>
                                <DropShadowEffect Color="{DynamicResource AppSpGlowColor}" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                            </ProgressBar.Effect>
                        </ProgressBar>
                        <TextBlock x:Name="SpTextBlock" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,3">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SpCurrentText}" Value="">
                                            <Setter Property="Visibility" Value="Hidden" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <TextBlock.Effect>
                                <DropShadowEffect Color="{DynamicResource AppProgressBarTextShadowColor}" BlurRadius="1" ShadowDepth="1" Opacity="0.8"/>
                            </TextBlock.Effect>
                            <Run Text="SP " Foreground="{DynamicResource AppProgressBarTextBrush}" />
                            <Run Text="{Binding SpCurrentText}" Foreground="{DynamicResource AppProgressBarTextBrush}" />
                            <Run Text=" / " Foreground="{DynamicResource AppProgressBarTextBrush}" />
                            <Run Text="{Binding SpMaxText}" Foreground="{DynamicResource AppProgressBarTextBrush}" />
                            <Run Text=" (" Foreground="{DynamicResource AppProgressBarTextBrush}" />
                            <Run Text="{Binding SpPercent, StringFormat={}{0:0}%}" Foreground="{DynamicResource AppProgressBarTextBrush}" />
                            <Run Text=")" Foreground="{DynamicResource AppProgressBarTextBrush}" />
                        </TextBlock>
                    </Grid>
                    
                    <Grid Margin="0,-1,0,0">
                        <ProgressBar x:Name="WtProgressBar" Value="{Binding WtPercent}"
                         Minimum="0" Maximum="100" Height="18" Background="{DynamicResource AppProgressBarBackgroundBrush}"
                         Foreground="{DynamicResource AppWtNormalBrush}"
                         BorderBrush="{DynamicResource AppWtBorderBrush}" BorderThickness="1">
                            <ProgressBar.Effect>
                                <DropShadowEffect Color="{DynamicResource AppWtGlowColor}" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                            </ProgressBar.Effect>
                        </ProgressBar>
                        <TextBlock x:Name="WtTextBlock" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,3">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WtCurrentText}" Value="">
                                            <Setter Property="Visibility" Value="Hidden" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <TextBlock.Effect>
                                <DropShadowEffect Color="{DynamicResource AppProgressBarTextShadowColor}" BlurRadius="1" ShadowDepth="1" Opacity="0.8"/>
                            </TextBlock.Effect>
                            <Run Text="{Binding WtLabelText}" Foreground="{DynamicResource AppProgressBarTextBrush}" />
                            <Run Text="{Binding WtCurrentText}" Foreground="{DynamicResource AppProgressBarTextBrush}" />
                            <Run Text=" / " Foreground="{DynamicResource AppProgressBarTextBrush}" />
                            <Run Text="{Binding WtMaxText}" Foreground="{DynamicResource AppProgressBarTextBrush}" />
                            <Run Text=" (" Foreground="{DynamicResource AppProgressBarTextBrush}" />
                            <Run Text="{Binding WtPercentValueText}" Foreground="{DynamicResource AppProgressBarTextBrush}" />
                            <Run Text=")" Foreground="{DynamicResource AppProgressBarTextBrush}" />
                        </TextBlock>
                    </Grid>
                </StackPanel>
                
                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock Text="{DynamicResource S.Main.Client}" FontSize="10" Foreground="{DynamicResource AppSubtleBrush}" Margin="0,0,0,2"/>
                    <ComboBox x:Name="ClientComboBox" ItemsSource="{Binding ProcessList}"
                              SelectedItem="{Binding SelectedProcess}"
                              DisplayMemberPath="DisplayName"
                              DropDownOpened="ProcessList_DropDownOpened"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              Width="130" Height="24" FontSize="12"
                              Background="{DynamicResource AppInputBrush}"
                              Foreground="Black" BorderBrush="{DynamicResource AppInputBorderBrush}" Margin="0,0,0,6">
                    </ComboBox>

                    <TextBlock Text="{DynamicResource S.Main.Profile}" FontSize="10" Foreground="{DynamicResource AppSubtleBrush}" Margin="0,0,0,2"/>
                    <ComboBox x:Name="ProfileComboBox" ItemsSource="{Binding ProfileList}"
                              SelectedItem="{Binding CurrentProfile}"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              Width="130" Height="24" FontSize="12"
                              Background="{DynamicResource AppInputBrush}"
                              BorderBrush="{DynamicResource AppInputBorderBrush}" Foreground="Black" Margin="0,0,0,8">
                    </ComboBox>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                        <Button Command="{Binding ToggleColorCommand}" ToolTip="Cycle Color"
                                FontFamily="pack://application:,,,/Fonts/#lucide" Content="&#xE1DD;" FontSize="16" Cursor="Hand"
                                Foreground="{DynamicResource AppTextBrush}"
                                Background="Transparent" BorderThickness="0" 
                                VerticalAlignment="Center" Margin="0,-1,8,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <TextBlock Text="{TemplateBinding Content}" FontFamily="{TemplateBinding FontFamily}" FontSize="{TemplateBinding FontSize}" Foreground="{TemplateBinding Foreground}" Background="Transparent" />
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Command="{Binding ToggleThemeCommand}" ToolTip="Toggle Theme"
                                FontFamily="pack://application:,,,/Fonts/#lucide" Content="&#xE1C2;" FontSize="16" Cursor="Hand"
                                Foreground="{DynamicResource AppTextBrush}"
                                Background="Transparent" BorderThickness="0" 
                                VerticalAlignment="Center" Margin="0,-1,8,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <TextBlock Text="{TemplateBinding Content}" FontFamily="{TemplateBinding FontFamily}" FontSize="{TemplateBinding FontSize}" Foreground="{TemplateBinding Foreground}" Background="Transparent" />
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Command="{Binding ToggleMiniModeCommand}" ToolTip="Toggle Mini Mode"
                                FontFamily="pack://application:,,,/Fonts/#lucide" FontSize="18" Cursor="Hand"
                                Foreground="{DynamicResource AppTextBrush}"
                                Background="Transparent" BorderThickness="0" 
                                VerticalAlignment="Center" Margin="0,-1,8,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <TextBlock Text="{TemplateBinding Content}" FontFamily="{TemplateBinding FontFamily}" FontSize="{TemplateBinding FontSize}" Foreground="{TemplateBinding Foreground}" Background="Transparent" />
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Content" Value="&#xE06D;" /> <!-- MenuDown -->
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMiniMode}" Value="True">
                                            <Setter Property="Content" Value="&#xE070;" /> <!-- MenuUp -->
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <!--
                        <Ellipse x:Name="ConnectionDot" Width="6" Height="6" Fill="{Binding ConnectionDotBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock x:Name="ConnectionLabelTextBlock" Text="{Binding ConnectionLabel}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AppSubtleBrush}" VerticalAlignment="Center" />
                        -->
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
        <TabControl Margin="0,0,0,2" Grid.Row="1" Grid.ColumnSpan="2">
            <TabControl.Style>
                <Style TargetType="TabControl" BasedOn="{StaticResource {x:Type TabControl}}">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsMiniMode}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsDialogVisible}" Value="True">
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <BlurEffect Radius="8" KernelType="Gaussian" RenderingBias="Performance"/>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Style>
            <TabControl.Template>
                <ControlTemplate TargetType="{x:Type TabControl}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{DynamicResource AppHeaderBrush}">
                            <helpers:CenteredWrapPanel x:Name="HeaderPanel" IsItemsHost="True" Margin="0,4,0,0"/>
                        </Border>
                        <Border x:Name="ContentPanel" Grid.Row="1" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter x:Name="PART_SelectedContentHost" ContentSource="SelectedContent" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </TabControl.Template>
            <TabItem Header="Skill Spammer" Padding="20,6">
                <views:SkillSpammerView DataContext="{Binding SkillSpammer}" />
            </TabItem>
            <TabItem Header="Skill Timer" Padding="20,6">
                <views:SkillTimerView DataContext="{Binding SkillTimer}" />
            </TabItem>
            <TabItem Header="Autopot" Padding="20,6">
                <views:AutopotView DataContext="{Binding}" />
            </TabItem>
            <TabItem Header="Autobuff" Padding="20,6">
                <TabControl x:Name="AutobuffTabControl" Style="{StaticResource SubTabControlStyle}" 
                            Loaded="AutobuffTabControl_Loaded" SelectionChanged="AutobuffTabControl_SelectionChanged">
                    <TabItem Style="{StaticResource SubTabItemStyle}" Width="80">
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="pack://application:,,,/Fonts/#lucide" Text="&#xE151;" FontSize="14" Margin="0,0,4,0"/>
                                <TextBlock Text="{DynamicResource S.Autobuff.SubSearch}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </TabItem.Header>
                        <views:AutobuffSearchView DataContext="{Binding AutobuffSearch}" />
                    </TabItem>
                    <TabItem Header="{DynamicResource S.Autobuff.SubSkills}" Style="{StaticResource SubTabItemStyle}">
                        <views:AutobuffSkillView DataContext="{Binding AutobuffSkill}" />
                    </TabItem>
                    <TabItem Header="{DynamicResource S.Autobuff.SubItems}" Style="{StaticResource SubTabItemStyle}">
                        <views:AutobuffItemView DataContext="{Binding AutobuffItem}" />
                    </TabItem>
                    <TabItem Header="{DynamicResource S.Autobuff.SubOrder}" Style="{StaticResource SubTabItemStyle}">
                        <views:AutobuffOrderView DataContext="{Binding AutobuffOrder}" />
                    </TabItem>
                </TabControl>
            </TabItem>
            <TabItem Header="Songs" Padding="20,6">
                <views:MacroSongView DataContext="{Binding MacroSong}" />
            </TabItem>
            <TabItem Header="Macro Switch" Padding="20,6">
                <views:MacroSwitchView DataContext="{Binding MacroSwitch}" />
            </TabItem>
            <TabItem Header="ATK x DEF" Padding="20,6">
                <views:AtkDefView DataContext="{Binding AtkDef}" />
            </TabItem>
            <TabItem Header="{DynamicResource S.Tab.Debuffs}" Width="116">
                <views:DebuffsView DataContext="{Binding Debuffs}" />
            </TabItem>
            <TabItem Header="{DynamicResource S.Tab.Misc}" Width="116">
                <views:MiscView DataContext="{Binding Misc}" />
            </TabItem>
            <TabItem Header="Auto Off" Width="116">
                <views:AutoOffView DataContext="{Binding AutoOff}" />
            </TabItem>
            <TabItem Header="{DynamicResource S.Tab.Profiles}" Width="116">
                <views:ProfilesView DataContext="{Binding Profiles}" />
            </TabItem>
            <TabItem Header="{DynamicResource S.Tab.Settings}" Width="116">
                <views:SettingsView DataContext="{Binding Settings}" />
            </TabItem>
            <TabItem Header="{DynamicResource S.Tab.About}" Width="116">
                <views:AboutView />
            </TabItem>
        </TabControl>

        <!-- Debug View Panel -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" Height="{Binding Settings.DebugViewHeight}" 
                Background="#0c0c0c" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,1,0,0">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Settings.DebugView}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            
            <RichTextBox views:LogViewHelper.LogMessages="{Binding LogMessages}"
                         views:LogViewHelper.AutoScroll="True"
                         Background="Transparent" 
                         BorderThickness="0"
                         IsReadOnly="True" 
                         IsDocumentEnabled="True"
                         Margin="0,6,0,6"
                         Padding="0"
                         FontFamily="Consolas"
                         FontSize="10"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled">
                <RichTextBox.Resources>
                    <Style TargetType="{x:Type Paragraph}">
                        <Setter Property="Margin" Value="0,1"/>
                    </Style>
                </RichTextBox.Resources>
            </RichTextBox>
        </Border>

        <!-- Ã¢â€â‚¬Ã¢â€â‚¬ Dialog Overlay Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬ -->
        <Grid Visibility="{Binding IsDialogVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
              Panel.ZIndex="9999" Grid.RowSpan="2" Grid.ColumnSpan="2">
            
            <Border Background="#66000000">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CurrentDialogContent.CancelCommand}" />
