<Window x:Class="ORTools.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ORTools.UI.ViewModels"
        xmlns:views="clr-namespace:ORTools.UI.Views"
        xmlns:helpers="clr-namespace:ORTools.UI.Helpers"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="{Binding AppTitle}"
        Width="731"
        Height="675"
        MinWidth="600"
        MinHeight="500"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        FontFamily="Segoe UI" Background="{DynamicResource AppBaseBrush}">
    <Window.Style>
        <Style TargetType="Window">
            <Setter Property="ResizeMode" Value="CanMinimize"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Settings.AllowResizingWindow}" Value="True">
                    <Setter Property="ResizeMode" Value="CanResize"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Style>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="171*"/>
            <ColumnDefinition Width="649*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <tb:TaskbarIcon x:Name="AppTrayIcon"
                        IconSource="{Binding TrayIconSource}"
                        ToolTipText="{Binding AppTitle}"
                        DoubleClickCommand="{Binding ShowWindowCommand}">
            <tb:TaskbarIcon.Style>
                <Style TargetType="tb:TaskbarIcon">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Settings.DisableSystray}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </tb:TaskbarIcon.Style>
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="{Binding ToggleButtonText}" Command="{Binding ToggleApplicationCommand}" />
                    <MenuItem Header="Profiles" ItemsSource="{Binding ProfileList}">
                        <MenuItem.ItemContainerStyle>
                            <Style TargetType="MenuItem">
                                <Setter Property="Header" Value="{Binding}" />
                                <Setter Property="Command" Value="{Binding DataContext.SelectProfileCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                <Setter Property="CommandParameter" Value="{Binding}" />
                                <Setter Property="IsCheckable" Value="True" />
                                <Setter Property="IsChecked">
                                    <Setter.Value>
                                        <MultiBinding Converter="{StaticResource EqualityMultiConverter}">
                                            <Binding Path="." />
                                            <Binding Path="DataContext.CurrentProfile" RelativeSource="{RelativeSource AncestorType=ContextMenu}" />
                                        </MultiBinding>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </MenuItem.ItemContainerStyle>
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="Exit" Command="{Binding ExitAppCommand}" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
        <Border x:Name="HeaderPanel" VerticalAlignment="Top" 
            Padding="10,8" Background="{DynamicResource AppHeaderBrush}" Grid.ColumnSpan="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="70" />
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0"
                    VerticalAlignment="Center"
                    Margin="0,0,16,0" Height="0"/>

                <Image Width="96" Source="{Binding AppLogoSource}" HorizontalAlignment="Left" Grid.ColumnSpan="2"/>

                <StackPanel Grid.Column="1"
                    VerticalAlignment="Center" Margin="40,0,0,0" Grid.IsSharedSizeScope="True">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="28" SharedSizeGroup="LabelCol" />
                            <ColumnDefinition Width="Auto" SharedSizeGroup="TextCol" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <Grid VerticalAlignment="Center">
                                <TextBlock Text="{Binding CharacterName}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" HorizontalAlignment="Left" />
                                <TextBlock x:Name="MapNameTextBlock" Text="{Binding MapName}" FontSize="16" Foreground="{DynamicResource AppMapNameBrush}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                            </Grid>
                            <TextBlock x:Name="JobNameTextBlock" Text="{Binding JobName}"
                                       FontSize="11" Foreground="{DynamicResource AppSubtleBrush}"
                                       Margin="0,1,0,0" HorizontalAlignment="Left" />
                                <TextBlock Text="{Binding InfoLine}" 
                                       FontSize="11" Margin="0,3,0,0" Foreground="{DynamicResource AppTextBrush}" HorizontalAlignment="Left" />
                            </StackPanel>

                        <StackPanel Grid.Column="1" Grid.ColumnSpan="2" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="6,0,0,0">
                            <Button x:Name="ToggleApplicationButton" Content="{Binding ToggleButtonText}"
                                    Command="{Binding ToggleApplicationCommand}"
                                    IsEnabled="{Binding IsClientConnected}"
                                    Style="{StaticResource ToggleApplicationButtonStyle}"
                                    Height="24" Width="100" FontSize="11" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="Key:" FontSize="10" Foreground="{DynamicResource AppSubtleBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBox x:Name="ToggleKeyTextBox" Text="{Binding ToggleKey, Mode=TwoWay, Converter={StaticResource KeyToStringConverter}}"
                                         PreviewKeyDown="ToggleKeyTextBox_PreviewKeyDown"
                                         Width="50" Height="22" MaxLength="10" FontSize="11"
                                         Style="{StaticResource KeyTextBoxStyle}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="28" SharedSizeGroup="LabelCol" />
                            <ColumnDefinition Width="Auto" SharedSizeGroup="TextCol" />
                        </Grid.ColumnDefinitions>
                        <ProgressBar x:Name="HpProgressBar" Value="{Binding HpPercent}"
                         Minimum="0"
                         Maximum="100"
                         Height="11"
                         Background="{DynamicResource AppInputBrush}"
                         Foreground="{DynamicResource AppSuccessBrush}" Grid.Column="0" />
                        <TextBlock Grid.Column="1" Text="HP" Foreground="{DynamicResource AppSubtleBrush}" FontSize="10" VerticalAlignment="Center" Margin="6,0,4,0" TextAlignment="Right" />
                        <TextBlock x:Name="HpTextBlock" Grid.Column="2"
                       Text="{Binding HpText}"
                       FontSize="10"
                       Foreground="{DynamicResource AppSubtleBrush}"
                       VerticalAlignment="Center"
                       Margin="0,0,0,0"
                       MinWidth="100" />
                    </Grid>
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="28" SharedSizeGroup="LabelCol" />
                            <ColumnDefinition Width="Auto" SharedSizeGroup="TextCol" />
                        </Grid.ColumnDefinitions>
                        <ProgressBar x:Name="SpProgressBar" Value="{Binding SpPercent}"
                         Minimum="0"
                         Maximum="100"
                         Height="11"
                         Background="{DynamicResource AppInputBrush}"
                         Foreground="{DynamicResource AppInfoBrush}" Grid.Column="0" Margin="0,1,0,1" />
                        <TextBlock Grid.Column="1" Text="SP" Foreground="{DynamicResource AppSubtleBrush}" FontSize="10" VerticalAlignment="Center" Margin="6,0,4,0" TextAlignment="Right" />
                        <TextBlock x:Name="SpTextBlock" Grid.Column="2"
                       Text="{Binding SpText}"
                       FontSize="10"
                       Foreground="{DynamicResource AppSubtleBrush}"
                       VerticalAlignment="Center"
                       Margin="0,0,0,0"
                       MinWidth="100" />
                    </Grid>
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="28" SharedSizeGroup="LabelCol" />
                            <ColumnDefinition Width="Auto" SharedSizeGroup="TextCol" />
                        </Grid.ColumnDefinitions>
                        <ProgressBar x:Name="WtProgressBar" Value="{Binding WtPercent}"
                         Minimum="0"
                         Maximum="100"
                         Height="11"
                         Background="{DynamicResource AppInputBrush}"
                         Foreground="{DynamicResource AppWeightBrush}" Grid.Column="0" />
                        <TextBlock Grid.Column="1" Text="WT" Foreground="{DynamicResource AppSubtleBrush}" FontSize="10" VerticalAlignment="Bottom" Margin="6,0,4,0" TextAlignment="Right" />
                        <TextBlock x:Name="WtTextBlock" Grid.Column="2"
                       Text="{Binding WtText}"
                       FontSize="10"
                       Foreground="{DynamicResource AppSubtleBrush}"
                       VerticalAlignment="Center"
                       Margin="0,0,0,0"
                       MinWidth="100" />
                    </Grid>
                </StackPanel>
                
                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock Text="Client" FontSize="10" Foreground="{DynamicResource AppSubtleBrush}" Margin="0,0,0,2"/>
                    <ComboBox x:Name="ClientComboBox" ItemsSource="{Binding ProcessList}"
                              SelectedItem="{Binding SelectedProcess}"
                              DisplayMemberPath="DisplayName"
                              DropDownOpened="ProcessList_DropDownOpened"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              Width="130" Height="24" FontSize="12"
                              Background="{DynamicResource AppInputBrush}"
                              Foreground="Black" BorderBrush="{DynamicResource AppInputBorderBrush}" Margin="0,0,0,6">
                    </ComboBox>

                    <TextBlock Text="Profile" FontSize="10" Foreground="{DynamicResource AppSubtleBrush}" Margin="0,0,0,2"/>
                    <ComboBox x:Name="ProfileComboBox" ItemsSource="{Binding ProfileList}"
                              SelectedItem="{Binding CurrentProfile}"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              Width="130" Height="24" FontSize="12"
                              Background="{DynamicResource AppInputBrush}"
                              BorderBrush="{DynamicResource AppInputBorderBrush}" Foreground="Black" Margin="0,0,0,8">
                    </ComboBox>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                        <Button Command="{Binding ToggleThemeCommand}" ToolTip="Toggle Theme"
                                FontFamily="Segoe MDL2 Assets" Content="&#xEA80;" FontSize="13" Cursor="Hand"
                                Foreground="{DynamicResource AppTextBrush}"
                                Background="Transparent" BorderThickness="0" 
                                VerticalAlignment="Center" Margin="0,-1,8,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <TextBlock Text="{TemplateBinding Content}" FontFamily="{TemplateBinding FontFamily}" FontSize="{TemplateBinding FontSize}" Foreground="{TemplateBinding Foreground}" Background="Transparent" />
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Command="{Binding ToggleMiniModeCommand}" ToolTip="Toggle Mini Mode"
                                FontFamily="Segoe MDL2 Assets" FontSize="11" Cursor="Hand"
                                Foreground="{DynamicResource AppTextBrush}"
                                Background="Transparent" BorderThickness="0" 
                                VerticalAlignment="Center" Margin="0,-1,8,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <TextBlock Text="{TemplateBinding Content}" FontFamily="{TemplateBinding FontFamily}" FontSize="{TemplateBinding FontSize}" Foreground="{TemplateBinding Foreground}" Background="Transparent" />
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Content" Value="&#xE70E;" /> <!-- ChevronDown/Expand -->
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMiniMode}" Value="True">
                                            <Setter Property="Content" Value="&#xE70D;" /> <!-- ChevronUp/Collapse -->
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <!--
                        <Ellipse x:Name="ConnectionDot" Width="6" Height="6" Fill="{Binding ConnectionDotBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock x:Name="ConnectionLabelTextBlock" Text="{Binding ConnectionLabel}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AppSubtleBrush}" VerticalAlignment="Center" />
                        -->
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
        <TabControl Margin="0,3,0,2" Grid.Row="1" Grid.ColumnSpan="2">
            <TabControl.Style>
                <Style TargetType="TabControl" BasedOn="{StaticResource {x:Type TabControl}}">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsMiniMode}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Style>
            <TabControl.Template>
                <ControlTemplate TargetType="{x:Type TabControl}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <helpers:CenteredWrapPanel x:Name="HeaderPanel" IsItemsHost="True" Grid.Row="0" Margin="0,0,0,2"/>
                        <Border x:Name="ContentPanel" Grid.Row="1" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter x:Name="PART_SelectedContentHost" ContentSource="SelectedContent" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </TabControl.Template>
            <TabItem Header="Skill Spammer" Padding="20,6">
                <views:SkillSpammerView DataContext="{Binding SkillSpammer}" />
            </TabItem>
            <TabItem Header="Skill Timer" Padding="20,6">
                <views:SkillTimerView DataContext="{Binding SkillTimer}" />
            </TabItem>
            <TabItem Header="Autopot" Padding="20,6">
                <views:AutopotView DataContext="{Binding}" />
            </TabItem>
            <TabItem Header="Autobuff" Padding="20,6">
                <TabControl Style="{StaticResource SubTabControlStyle}">
                    <TabItem Header="Skills" Style="{StaticResource SubTabItemStyle}">
                        <views:AutobuffSkillView DataContext="{Binding AutobuffSkill}" />
                    </TabItem>
                    <TabItem Header="Items" Style="{StaticResource SubTabItemStyle}">
                        <views:AutobuffItemView DataContext="{Binding AutobuffItem}" />
                    </TabItem>
                    <TabItem Header="Order" Style="{StaticResource SubTabItemStyle}">
                        <views:AutobuffOrderView DataContext="{Binding AutobuffOrder}" />
                    </TabItem>
                </TabControl>
            </TabItem>
            <TabItem Header="Songs" Padding="20,6">
                <views:MacroSongView DataContext="{Binding MacroSong}" />
            </TabItem>
            <TabItem Header="Macro Switch" Padding="20,6">
                <views:MacroSwitchView DataContext="{Binding MacroSwitch}" />
            </TabItem>
            <TabItem Header="ATK x DEF" Padding="20,6">
                <views:AtkDefView DataContext="{Binding AtkDef}" />
            </TabItem>
            <TabItem Header="Debuffs" Width="116">
                <views:DebuffsView DataContext="{Binding Debuffs}" />
            </TabItem>
            <TabItem Header="Misc" Width="116">
                <views:MiscView DataContext="{Binding Misc}" />
            </TabItem>
            <TabItem Header="Auto Off" Width="116">
                <views:AutoOffView DataContext="{Binding AutoOff}" />
            </TabItem>
            <TabItem Header="Profiles" Width="116">
                <views:ProfilesView DataContext="{Binding Profiles}" />
            </TabItem>
            <TabItem Header="Settings" Width="116">
                <views:SettingsView DataContext="{Binding Settings}" />
            </TabItem>
            <TabItem Header="About" Width="116">
                <views:AboutView />
            </TabItem>
        </TabControl>
    </Grid>
</Window>