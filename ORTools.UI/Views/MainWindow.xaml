<Window x:Class="ORTools.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ORTools.UI.ViewModels"
        Title="OSRO Tools v1.99.0/HR"
        Width="820"
        Height="620"
        MinWidth="640"
        MinHeight="480"
        FontFamily="Segoe UI" Background="#FF222222">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0"
            Padding="10,8" Background="#FF2D2D2D">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="70" />
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0"
                    VerticalAlignment="Center"
                    Margin="0,0,16,0" Height="0"/>

                <Image Width="96" Source="/Views/ortools.png" RenderTransformOrigin="1.146,0.21" HorizontalAlignment="Left" Margin="0,0,0,39" Grid.ColumnSpan="2"/>

                <StackPanel Grid.Column="1"
                    VerticalAlignment="Center" Height="87" Margin="40,0,0,0">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding CharacterName}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource AppTextBrush}" />
                        <TextBlock Grid.Column="1"
                       Text="{Binding MapName}"
                       FontSize="11"
                       Foreground="#6868A0"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0" />
                    </Grid>

                    <TextBlock Text="{Binding InfoLine}"
                     FontSize="11"
                     Foreground="#6868A0"
                     Margin="0,3,0,0" />
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ProgressBar Value="{Binding HpPercent}"
                         Minimum="0"
                         Maximum="100"
                         Height="11"
                         Background="{StaticResource AppInputBrush}"
                         Foreground="{StaticResource AppSuccessBrush}" />
                        <TextBlock Grid.Column="1"
                       Text="{Binding HpText}"
                       FontSize="10"
                       Foreground="{StaticResource AppSubtleBrush}"
                       VerticalAlignment="Center"
                       Margin="6,0,0,0"
                       MinWidth="140" />
                    </Grid>
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="31*" />
                            <ColumnDefinition Width="407*"/>
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ProgressBar Value="{Binding SpPercent}"
                         Minimum="0"
                         Maximum="100"
                         Height="11"
                         Background="{StaticResource AppInputBrush}"
                         Foreground="{StaticResource AppInfoBrush}" Grid.ColumnSpan="2" Margin="0,1,0,1" />
                        <TextBlock Grid.Column="2"
                       Text="{Binding SpText}"
                       FontSize="10"
                       Foreground="{StaticResource AppSubtleBrush}"
                       VerticalAlignment="Center"
                       Margin="6,0,0,0"
                       MinWidth="140" />
                    </Grid>
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ProgressBar Value="{Binding WtPercent}"
                         Minimum="0"
                         Maximum="100"
                         Height="11"
                         Background="{StaticResource AppInputBrush}"
                         Foreground="#CD7F32" />
                        <TextBlock Grid.Column="1"
                       Text="{Binding WtText}"
                       FontSize="10"
                       Foreground="{StaticResource AppSubtleBrush}"
                       VerticalAlignment="Center"
                       Margin="6,0,0,0"
                       MinWidth="140" />
                    </Grid>
                </StackPanel>
                <StackPanel Grid.Column="2"
                    VerticalAlignment="Center"
                    Margin="12,0,0,0" Height="70">
                    <ComboBox ItemsSource="{Binding ProfileList}"
                    SelectedItem="{Binding CurrentProfile}"
                    Width="130"
                    Height="26"
                    FontSize="12"
                    Background="{StaticResource AppInputBrush}"
                    BorderBrush="{StaticResource AppInputBorderBrush}" Foreground="Black" />
                    <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Center"
                      Margin="0,6,0,0">
                        <Ellipse Width="10"
                     Height="10"
                     VerticalAlignment="Center"
                     Fill="{Binding ConnectionDotBrush}" />
                        <Button Content="{Binding ToggleButtonText}"
                    Command="{Binding ToggleApplicationCommand}"
                    IsEnabled="{Binding IsClientConnected}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Height="28"
                    FontSize="12"
                    Margin="8,0,0,0" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
        <Border
            Padding="10,5"
            BorderThickness="0,0,0,1"
            BorderBrush="{StaticResource AppBorderBrush}" Margin="0,127,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Client:"
                   Foreground="#FFC1C1C1"
                   FontSize="12"
                   VerticalAlignment="Center"
                   Margin="0,0,8,0" />
                <ComboBox ItemsSource="{Binding ProcessList}"
                  SelectedItem="{Binding SelectedProcess}"
                  Width="200"
                  Height="26"
                  FontSize="12"
                  Background="{StaticResource AppInputBrush}"
                  Foreground="{StaticResource AppTextBrush}"
                  BorderBrush="{StaticResource AppInputBorderBrush}" />
                <Button Content="↺"
                Command="{Binding RefreshProcessListCommand}"
                Width="28"
                Height="26"
                FontSize="14"
                Margin="8,0,0,0" />
                <Button Content="Connect"
                Command="{Binding ConnectToProcessCommand}"
                IsEnabled="{Binding HasSelectedProcess}"
                Style="{StaticResource PrimaryButtonStyle}"
                Height="26"
                FontSize="12"
                Padding="10,0"
                Margin="8,0,0,0" />
                <Button Content="Disconnect"
                Command="{Binding DisconnectClientCommand}"
                IsEnabled="{Binding IsClientConnected}"
                Style="{StaticResource DangerButtonStyle}"
                Height="26"
                FontSize="12"
                Padding="10,0"
                Margin="8,0,0,0" />
                <TextBlock Text="{Binding ConnectionLabel}"
                   Foreground="{StaticResource AppMutedBrush}"
                   FontSize="11"
                   VerticalAlignment="Center"
                   Margin="8,0,0,0" />
            </StackPanel>
        </Border>
        <TabControl Grid.Row="2" Margin="0,5,0,0">
            <TabItem Header="Autopot HP" Background="#FF232323">
                <Border Padding="16">
                    <TextBlock Text="Autopot HP - Phase 2"
                     FontStyle="Italic" Margin="-6,-6,-6,-6" />
                </Border>
            </TabItem>
            <TabItem Header="Autopot SP">
                <Border Padding="16">
                    <TextBlock Text="Autopot SP - Phase 2"
                     FontStyle="Italic" />
                </Border>
            </TabItem>
            <TabItem Header="Skill Timer">
                <Border Padding="16">
                    <TextBlock Text="Skill Timer - Phase 2"
                     FontStyle="Italic" />
                </Border>
            </TabItem>
            <TabItem Header="Skill Spammer">
                <Border Padding="16">
                    <TextBlock Text="Skill Spammer - Phase 2"
                     FontStyle="Italic" />
                </Border>
            </TabItem>
            <TabItem Header="Debuffs">
                <Border Padding="16">
                    <TextBlock Text="Debuffs - Phase 2"
                     FontStyle="Italic" />
                </Border>
            </TabItem>
            <TabItem Header="Auto Off">
                <Border Padding="16">
                    <TextBlock Text="Auto Off - Phase 2"
                     FontStyle="Italic" />
                </Border>
            </TabItem>
            <TabItem Header="Autobuff">
                <Border Padding="16">
                    <TextBlock Text="Autobuff - Phase 2"
                     FontStyle="Italic" />
                </Border>
            </TabItem>
            <TabItem Header="Transfer">
                <Border Padding="16">
                    <TextBlock Text="Transfer Helper - Phase 2"
                     FontStyle="Italic" />
                </Border>
            </TabItem>
            <TabItem Header="ATK/DEF">
                <Border Padding="16">
                    <TextBlock Text="ATK/DEF - Phase 2"
                     FontStyle="Italic" />
                </Border>
            </TabItem>
            <TabItem Header="Macro Switch">
                <Border Padding="16">
                    <TextBlock Text="Macro Switch - Phase 2"
                     FontStyle="Italic" />
                </Border>
            </TabItem>
            <TabItem Header="Songs">
                <Border Padding="16">
                    <TextBlock Text="Songs - Phase 2"
                     FontStyle="Italic" />
                </Border>
            </TabItem>
            <TabItem Header="Settings">
                <Border Padding="16">
                    <TextBlock Text="Settings - Phase 2"
                     FontStyle="Italic" />
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Window>