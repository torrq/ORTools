<UserControl x:Class="ORTools.UI.Views.ConfirmDeleteDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    
    <Border Background="{DynamicResource AppSurfaceBrush}" 
            BorderBrush="{DynamicResource AppBorderBrush}" 
            BorderThickness="1" 
            CornerRadius="8" 
            Padding="24"
            HorizontalAlignment="Center" 
            VerticalAlignment="Center">
        
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" Opacity="0.5" Direction="270" ShadowDepth="5"/>
        </Border.Effect>

        <StackPanel MinWidth="250">
            <TextBlock Text="Confirm Delete" Foreground="{DynamicResource AppDangerBrush}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16" HorizontalAlignment="Center"/>
            
            <TextBlock Text="{Binding MessageText}" Foreground="{DynamicResource AppTextBrush}" FontSize="14" Margin="0,0,0,24" TextWrapping="Wrap" MaxWidth="350" HorizontalAlignment="Center" TextAlignment="Center"/>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Cancel" Command="{Binding CancelCommand}" 
                        IsCancel="True"
                        Style="{StaticResource SecondaryButtonStyle}" 
                        Width="100" Height="32" Margin="0,0,16,0"
                        Foreground="{DynamicResource AppSubtleBrush}"
                        Background="Transparent"/>
                
                <Button Content="Delete" Command="{Binding ConfirmCommand}" 
                        IsDefault="True"
                        Style="{StaticResource PrimaryButtonStyle}" 
                        Background="{DynamicResource AppDangerBrush}"
                        Foreground="White"
                        Width="100" Height="32"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
