<UserControl x:Class="ORTools.UI.Views.AutoOffView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:controls="clr-namespace:ORTools.UI.Controls"
             xmlns:converters="clr-namespace:ORTools.UI.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="600">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:HourSelectedConverter x:Key="HourSelectedConverter"/>

        <Style x:Key="HourChipButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Background" Value="{DynamicResource AppInputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppInputBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="13">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppPrimaryHoverBrush}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AppPrimaryHoverBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource HourSelectedConverter}">
                            <Binding Path="." />
                            <Binding Path="DataContext.AutoOffTime" RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="Background" Value="{DynamicResource AppPrimaryBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AppPrimaryBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left Column: Timer, full height -->
        <GroupBox Grid.Column="0" Padding="16" VerticalAlignment="Stretch">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="pack://application:,,,/Fonts/#lucide" Text="&#xE087;" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock Text="Auto Off Timer" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
            </GroupBox.Header>
            <StackPanel TextElement.FontSize="13" VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,8">
                    <controls:RadialTimePicker Value="{Binding AutoOffTime, Delay=150, Mode=TwoWay}"
                                                Maximum="{Binding MaxTime}"
                                                Minimum="1"
                                                SnapMinutes="5"
                                                IsRunning="{Binding IsTimerRunning}"
                                                IsPaused="{Binding IsTimerPaused}"
                                                RunningTotalMinutes="{Binding RunningTotalMinutes}"
                                                RunningRemainingSeconds="{Binding RunningRemainingSeconds}"
                                                RemainingText="{Binding RemainingCombinedText}" />
                </StackPanel>

                <ItemsControl ItemsSource="{Binding QuickButtons}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,14" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding StringFormat='{}{0}h'}"
                                    Command="{Binding DataContext.SetTimeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource HourChipButtonStyle}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Command="{Binding ToggleTimerCommand}" HorizontalAlignment="Stretch" Padding="8,6" FontFamily="pack://application:,,,/Fonts/#lucide" FontSize="18" ToolTip="Start / Stop the countdown">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                <Setter Property="Content" Value="&#xE13C;"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTimerRunning}" Value="True">
                                        <Setter Property="Content" Value="&#xE167;"/>
                                        <Setter Property="Background" Value="{DynamicResource AppDangerBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Grid.Column="2" Command="{Binding PauseTimerCommand}" IsEnabled="{Binding IsTimerRunning}"
                            HorizontalAlignment="Stretch" Padding="8,6" FontSize="18" FontFamily="pack://application:,,,/Fonts/#lucide" ToolTip="Pause / resume the countdown">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                <Setter Property="Content" Value="&#xE12E;"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTimerPaused}" Value="True">
                                        <Setter Property="Content" Value="&#xE13C;"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </StackPanel>
        </GroupBox>

        <!-- Right Column: Timer Automation, Overweight, Trigger Actions -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <GroupBox Grid.Row="0" Padding="12,8">
                <GroupBox.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock FontFamily="pack://application:,,,/Fonts/#lucide" Text="&#xE550;" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="Timer Automation" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                </GroupBox.Header>
                <StackPanel TextElement.FontSize="13" VerticalAlignment="Center" Margin="0,4,0,4">
                    <CheckBox Content="Auto-start timer when turned on" IsChecked="{Binding DataContext.Settings.StartAutoOffTimerOnEnable, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,12" HorizontalAlignment="Left" Cursor="Hand" />
                    <CheckBox Content="Auto-stop timer when turned off" IsChecked="{Binding DataContext.Settings.ClearAutoOffTimerOnDisable, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="{DynamicResource AppTextBrush}" HorizontalAlignment="Left" Cursor="Hand" />
                </StackPanel>
            </GroupBox>

            <GroupBox Grid.Row="2" Padding="8,6">
                <GroupBox.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock FontFamily="pack://application:,,,/Fonts/#lucide" Text="&#xE530;" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="Overweight Auto Off" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                </GroupBox.Header>
                <StackPanel TextElement.FontSize="13" VerticalAlignment="Center">
                    <CheckBox Content="Enable Auto Off on Overweight" IsChecked="{Binding AutoOffOverweight}" Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,8" HorizontalAlignment="Center" Cursor="Hand" />
                    
                    <StackPanel Orientation="Horizontal" IsEnabled="{Binding AutoOffOverweight}" HorizontalAlignment="Center" RenderTransformOrigin="0.122,0.507">
                        <RadioButton Content="50%" IsChecked="{Binding AutoOffOverweightMode, Converter={StaticResource EqualityToBooleanConverter}, ConverterParameter=50}" Foreground="{DynamicResource AppTextBrush}" Margin="0,0,16,0" VerticalAlignment="Center" VerticalContentAlignment="Center" Cursor="Hand">
                            <RadioButton.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="pack://application:,,,/Icons/ui/weight50.png" Stretch="None" Margin="0,0,6,0" 
                                               RenderOptions.BitmapScalingMode="NearestNeighbor" SnapsToDevicePixels="True" />
                                        <TextBlock Text="50%" VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </RadioButton.ContentTemplate>
                        </RadioButton>
                        <RadioButton Content="90%" IsChecked="{Binding AutoOffOverweightMode, Converter={StaticResource EqualityToBooleanConverter}, ConverterParameter=90}" Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" VerticalContentAlignment="Center" Cursor="Hand">
                            <RadioButton.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="pack://application:,,,/Icons/ui/weight90.png" Stretch="None" Margin="0,0,6,0" 
                                               RenderOptions.BitmapScalingMode="NearestNeighbor" SnapsToDevicePixels="True" />
                                        <TextBlock Text="90%" VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </RadioButton.ContentTemplate>
                        </RadioButton>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Grid.Row="4" Padding="8">
                <GroupBox.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock FontFamily="pack://application:,,,/Fonts/#lucide" Text="&#xE1B4;" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="Trigger Actions" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                </GroupBox.Header>
                <StackPanel TextElement.FontSize="13" VerticalAlignment="Center">
                    <TextBlock Text="When Auto Off is triggered, perform these actions in order:" TextWrapping="Wrap" Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,12" />
                    
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="1." VerticalAlignment="Center" Foreground="{DynamicResource AppTextBrush}"/>
                        <TextBlock Grid.Column="1" Text="Send Alt + Key:" VerticalAlignment="Center" Foreground="{DynamicResource AppTextBrush}"/>
                        <TextBox Grid.Column="2" Text="{Binding AutoOffKey1, Mode=TwoWay, Converter={StaticResource KeyToStringConverter}}"
                                 PreviewKeyDown="Key1TextBox_PreviewKeyDown"
                                 Style="{StaticResource KeyTextBoxStyle}" HorizontalAlignment="Center" />
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="2." VerticalAlignment="Center" Foreground="{DynamicResource AppTextBrush}"/>
                        <TextBlock Grid.Column="1" Text="Send Alt + Key:" VerticalAlignment="Center" Foreground="{DynamicResource AppTextBrush}"/>
                        <TextBox Grid.Column="2" Text="{Binding AutoOffKey2, Mode=TwoWay, Converter={StaticResource KeyToStringConverter}}"
                                 PreviewKeyDown="Key2TextBox_PreviewKeyDown"
                                 Style="{StaticResource KeyTextBoxStyle}" HorizontalAlignment="Center" />
                    </Grid>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="3." VerticalAlignment="Center" Foreground="{DynamicResource AppTextBrush}"/>
                        <TextBlock Grid.Column="1" Text="Stop Game Client" VerticalAlignment="Center" Foreground="{DynamicResource AppTextBrush}"/>
                        <CheckBox Grid.Column="2" IsChecked="{Binding AutoOffKillClient}" VerticalAlignment="Center" Cursor="Hand" />
                    </Grid>
                </StackPanel>
            </GroupBox>
        </Grid>
    </Grid>
</UserControl>
