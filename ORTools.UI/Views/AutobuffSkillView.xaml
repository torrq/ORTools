<UserControl x:Class="ORTools.UI.Views.AutobuffSkillView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ORTools.UI.ViewModels" xmlns:helpers="clr-namespace:ORTools.UI.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             Background="Transparent">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
            <ItemsControl ItemsSource="{Binding SkillGroups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,24">
                            <!-- Group Header -->
                            <Border BorderThickness="0,0,0,1" BorderBrush="{StaticResource AppBorderBrush}" Margin="0,0,0,10" Padding="0,0,0,4">
                                <TextBlock Text="{Binding GroupName}" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource AppTextBrush}" />
                            </Border>

                            <!-- Group Items -->
                            <ItemsControl ItemsSource="{Binding Items}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" ItemWidth="240" ItemHeight="48" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="10,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="65"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Fallback background just in case the icon has transparency -->
                                            <Border Width="24" Height="24" Background="Transparent" CornerRadius="2" Margin="0,0,8,0" VerticalAlignment="Center">
                                                <Image Source="{Binding ImagePath}" Stretch="None"
                                                       RenderOptions.BitmapScalingMode="NearestNeighbor" SnapsToDevicePixels="True"/>
                                            </Border>

                                            <TextBlock Grid.Column="1" Text="{Binding DisplayName}" VerticalAlignment="Center"
                                                       Foreground="{StaticResource AppTextBrush}" FontSize="14" TextTrimming="CharacterEllipsis" Margin="0,0,8,0"/>

                                            <TextBox Grid.Column="2" Text="{Binding Key, Mode=TwoWay}"
                                                     PreviewKeyDown="KeyTextBox_PreviewKeyDown"
                                                     Style="{StaticResource KeyTextBoxStyle}" 
                                                     Height="28" FontSize="14" HorizontalAlignment="Right" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Settings -->
        <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="{StaticResource AppBorderBrush}" Margin="0,10,0,0" Padding="0,16,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="Delay (ms):" FontSize="14" Foreground="{StaticResource AppSubtleBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Text="{Binding Delay, UpdateSourceTrigger=PropertyChanged, Delay=500}" 
                         helpers:InputHelper.IsNumericInput="True"
                         Style="{StaticResource NumericTextBoxStyle}" Width="70" Height="28" FontSize="14" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
