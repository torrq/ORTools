<UserControl x:Class="ORTools.UI.Views.SkillTimerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ORTools.UI.ViewModels" xmlns:helpers="clr-namespace:ORTools.UI.Helpers"
             Background="Transparent">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="30"/> <!-- Spacing -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Header -->
            <Grid Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="ON" Foreground="{DynamicResource AppSubtleBrush}" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="KEY" Foreground="{DynamicResource AppSubtleBrush}" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="DELAY (ms)" Foreground="{DynamicResource AppSubtleBrush}" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="CLICK MODE" Foreground="{DynamicResource AppSubtleBrush}" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="4" Text="ALT-KEY" Foreground="{DynamicResource AppSubtleBrush}" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>

            <!-- Right Header -->
            <Grid Grid.Column="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="ON" Foreground="{DynamicResource AppSubtleBrush}" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="KEY" Foreground="{DynamicResource AppSubtleBrush}" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="DELAY (ms)" Foreground="{DynamicResource AppSubtleBrush}" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="CLICK MODE" Foreground="{DynamicResource AppSubtleBrush}" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="4" Text="ALT-KEY" Foreground="{DynamicResource AppSubtleBrush}" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Grid>

        <!-- Slots Area -->
        <Grid Grid.Row="1">
            <!-- Divider -->
            <Border HorizontalAlignment="Center" Width="1" Background="{DynamicResource AppSubtleBrush}" Opacity="0.2" Margin="0,0,0,10"/>

            <ItemsControl ItemsSource="{Binding Slots}" Margin="0,0,-30,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2" HorizontalAlignment="Stretch" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,30,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox IsChecked="{Binding Enabled}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>

                        <TextBox Grid.Column="1" Text="{Binding Key, Mode=TwoWay, Converter={StaticResource KeyToStringConverter}}"
                                 PreviewKeyDown="KeyTextBox_PreviewKeyDown"
                                 Style="{StaticResource KeyTextBoxStyle}" HorizontalAlignment="Center" Width="60" />

                        <TextBox Grid.Column="2" Text="{Binding Delay, UpdateSourceTrigger=PropertyChanged, Delay=500}"
                                 helpers:InputHelper.IsNumericInput="True" helpers:InputHelper.NumericDefault="1000"
                                 Style="{StaticResource NumericTextBoxStyle}" HorizontalAlignment="Center" Width="70" />

                        <ComboBox Grid.Column="3" SelectedIndex="{Binding ClickMode}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Width="70" Height="24"
                                  Foreground="Black"
                                  BorderBrush="{DynamicResource AppInputBorderBrush}">
                            <ComboBoxItem Content="None"/>
                            <ComboBoxItem Content="Cursor"/>
                            <ComboBoxItem Content="Center"/>
                        </ComboBox>

                        <CheckBox Grid.Column="4" IsChecked="{Binding AltKey}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        </Grid>
    </Grid>
</UserControl>
