<UserControl x:Class="ORTools.UI.Views.SkillTimerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ORTools.UI.ViewModels" xmlns:helpers="clr-namespace:ORTools.UI.Helpers"
             Background="Transparent">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="60"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="ON" Foreground="{StaticResource AppSubtleBrush}" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="KEY" Foreground="{StaticResource AppSubtleBrush}" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="2" Text="DELAY (ms)" Foreground="{StaticResource AppSubtleBrush}" FontWeight="SemiBold" FontSize="11" Margin="12,0,0,0" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="3" Text="CLICK MODE" Foreground="{StaticResource AppSubtleBrush}" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="4" Text="ALT-KEY" Foreground="{StaticResource AppSubtleBrush}" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>

        <!-- Slots -->
        <ItemsControl Grid.Row="1" ItemsSource="{Binding Slots}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox IsChecked="{Binding Enabled}" 
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center"/>

                        <TextBox Grid.Column="1" Text="{Binding Key, Mode=TwoWay}"
                                 PreviewKeyDown="KeyTextBox_PreviewKeyDown"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                 Width="40" Height="24" MaxLength="10"
                                 Background="{StaticResource AppInputBrush}" 
                                 BorderBrush="{StaticResource AppInputBorderBrush}" 
                                 TextAlignment="Center"
                                 IsReadOnly="True" Cursor="Hand">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Key}" Value="None">
                                            <Setter Property="Foreground" Value="{StaticResource AppSubtleBrush}" />
                                            <Setter Property="FontWeight" Value="Normal" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <TextBox Grid.Column="2" Text="{Binding Delay, UpdateSourceTrigger=PropertyChanged, Delay=500}" 
                                 helpers:InputHelper.IsNumericInput="True"
                                 
                                 
                                 HorizontalAlignment="Left" VerticalAlignment="Center"
                                 Width="60" Height="24" Margin="12,0,0,0"
                                 Background="{StaticResource AppInputBrush}" 
                                 BorderBrush="{StaticResource AppInputBorderBrush}" 
                                 Foreground="{StaticResource AppTextBrush}" 
                                 TextAlignment="Center"/>

                        <ComboBox Grid.Column="3" SelectedIndex="{Binding ClickMode}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Width="70" Height="24"
                                  Foreground="Black"
                                  BorderBrush="{StaticResource AppInputBorderBrush}">
                            <ComboBoxItem Content="None"/>
                            <ComboBoxItem Content="Cursor"/>
                            <ComboBoxItem Content="Center"/>
                        </ComboBox>

                        <CheckBox Grid.Column="4" IsChecked="{Binding AltKey}" 
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
