<UserControl x:Class="ORTools.UI.Views.SkillTimerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ORTools.UI.ViewModels" xmlns:helpers="clr-namespace:ORTools.UI.Helpers"
             Background="Transparent">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="30"/> <!-- Spacing -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Header -->
            <Grid Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="105"/>
                    <ColumnDefinition Width="68"/>
                    <ColumnDefinition Width="48"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="ON" Foreground="{DynamicResource AppSubtleBrush}" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="KEY" Foreground="{DynamicResource AppSubtleBrush}" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="DELAY (ms)" Foreground="{DynamicResource AppSubtleBrush}" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,30,0"/>
                <TextBlock Grid.Column="3" Text="CLICK" Foreground="{DynamicResource AppSubtleBrush}" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="4" Text="ALT" Foreground="{DynamicResource AppSubtleBrush}" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>

            <!-- Right Header -->
            <Grid Grid.Column="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="105"/>
                    <ColumnDefinition Width="68"/>
                    <ColumnDefinition Width="48"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="ON" Foreground="{DynamicResource AppSubtleBrush}" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="KEY" Foreground="{DynamicResource AppSubtleBrush}" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="DELAY (ms)" Foreground="{DynamicResource AppSubtleBrush}" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,30,0"/>
                <TextBlock Grid.Column="3" Text="CLICK" Foreground="{DynamicResource AppSubtleBrush}" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="4" Text="ALT" Foreground="{DynamicResource AppSubtleBrush}" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Grid>

        <!-- Slots Area -->
        <Grid Grid.Row="1">
            <!-- Divider -->
            <Border HorizontalAlignment="Center" Width="1" Background="{DynamicResource AppSubtleBrush}" Opacity="0.2" Margin="0,0,0,10"/>

            <ItemsControl ItemsSource="{Binding Slots}" Margin="0,0,-30,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2" HorizontalAlignment="Stretch" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,30,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="105"/>
                            <ColumnDefinition Width="68"/>
                            <ColumnDefinition Width="48"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox IsChecked="{Binding Enabled}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>

                        <TextBox Grid.Column="1" Text="{Binding Key, Mode=TwoWay, Converter={StaticResource KeyToStringConverter}}"
                                 PreviewKeyDown="KeyTextBox_PreviewKeyDown"
                                 Style="{StaticResource KeyTextBoxStyle}" HorizontalAlignment="Center" Width="60" />

                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBox Text="{Binding Delay, UpdateSourceTrigger=PropertyChanged, Delay=500}"
                                     helpers:InputHelper.IsNumericInput="True" helpers:InputHelper.NumericDefault="1000"
                                     Style="{StaticResource NumericTextBoxStyle}" Width="75" />
                            <Button Command="{Binding OpenTimePickerCommand}" 
                                    Content="&#xE823;" FontFamily="Segoe MDL2 Assets" 
                                    FontSize="14" Width="24" Height="24" 
                                    Margin="2,0,4,0" Padding="0"
                                    Foreground="{DynamicResource AppSubtleBrush}" 
                                    Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" ToolTip="Open Time Picker">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                            <TextBlock x:Name="IconText" Text="{TemplateBinding Content}" FontFamily="{TemplateBinding FontFamily}" FontSize="{TemplateBinding FontSize}" Foreground="{TemplateBinding Foreground}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="IconText" Property="Foreground" Value="{DynamicResource AppPrimaryBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>

                        <ComboBox Grid.Column="3" SelectedIndex="{Binding ClickMode}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Width="60" Height="24"
                                  Foreground="Black"
                                  BorderBrush="{DynamicResource AppInputBorderBrush}">
                            <ComboBoxItem Content="None"/>
                            <ComboBoxItem Content="Cursor"/>
                            <ComboBoxItem Content="Center"/>
                        </ComboBox>

                        <CheckBox Grid.Column="4" IsChecked="{Binding AltKey}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center" Cursor="Hand">
                            <CheckBox.Template>
                                <ControlTemplate TargetType="CheckBox">
                                    <Image x:Name="Icon" Source="pack://application:,,,/Icons/Key/key_alt.png" 
                                           Stretch="None" RenderOptions.BitmapScalingMode="NearestNeighbor"
                                           Opacity="0.35"/>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Icon" Property="Opacity" Value="0.6"/>
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Icon" Property="Opacity" Value="1.0"/>
                                        </Trigger>
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsChecked" Value="True"/>
                                                <Condition Property="IsMouseOver" Value="True"/>
                                            </MultiTrigger.Conditions>
                                            <Setter TargetName="Icon" Property="Opacity" Value="0.8"/>
                                        </MultiTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </CheckBox.Template>
                        </CheckBox>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        </Grid>
    </Grid>
</UserControl>
