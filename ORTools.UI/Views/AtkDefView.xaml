<UserControl x:Class="ORTools.UI.Views.AtkDefView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:ORTools.UI.ViewModels"
             xmlns:helpers="clr-namespace:ORTools.UI.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance vm:AtkDefViewModel}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding Rows}" Margin="10">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="{DynamicResource AppSurfaceAltBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="4" Margin="0,0,0,6" Padding="10,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4*" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="6*" />
                            </Grid.ColumnDefinitions>

                            <!-- Left Side: Trigger Settings -->
                            <GroupBox Grid.Column="0" Header="Settings" Foreground="{DynamicResource AppSubtleBrush}" BorderBrush="{DynamicResource AppBorderBrush}" Margin="0" VerticalAlignment="Center">
                                <Grid Margin="10,12" MaxWidth="220" HorizontalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <Grid Grid.Row="0" Margin="0,0,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Spam Key" Foreground="{DynamicResource AppSubtleBrush}" FontSize="11" HorizontalAlignment="Left" />
                                        <CheckBox Grid.Column="1" Content="Click?" IsChecked="{Binding WithClick}" Foreground="{DynamicResource AppSubtleBrush}" FontSize="11" Margin="10,0,0,0" />
                                    </Grid>
                                    
                                    <TextBox Grid.Row="1" Text="{Binding SpammerKey, Mode=TwoWay, Converter={StaticResource KeyToStringConverter}}"
                                             Style="{StaticResource KeyTextBoxStyle}" 
                                             PreviewKeyDown="SpammerKey_PreviewKeyDown"
                                             HorizontalAlignment="Stretch" Width="NaN" Margin="0,0,0,10" Height="24" FontSize="12"/>
                                             
                                    <Grid Grid.Row="2" Margin="0,0,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Spam Delay" Foreground="{DynamicResource AppSubtleBrush}" FontSize="11" HorizontalAlignment="Left" />
                                        <TextBlock Grid.Column="2" Text="Switch Delay" Foreground="{DynamicResource AppSubtleBrush}" FontSize="11" HorizontalAlignment="Left" />
                                    </Grid>
                                    
                                    <Grid Grid.Row="3" Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding SpammerDelay, UpdateSourceTrigger=PropertyChanged, Delay=250}" Style="{StaticResource NumericTextBoxStyle}" Height="24" FontSize="12" HorizontalAlignment="Stretch" Width="NaN" helpers:InputHelper.IsNumericInput="True" helpers:InputHelper.NumericDefault="100" PreviewKeyDown="SpammerDelay_PreviewKeyDown"/>
                                        <TextBox Grid.Column="2" Text="{Binding SwitchDelay, UpdateSourceTrigger=PropertyChanged, Delay=250}" Style="{StaticResource NumericTextBoxStyle}" Height="24" FontSize="12" HorizontalAlignment="Stretch" Width="NaN" helpers:InputHelper.IsNumericInput="True" helpers:InputHelper.NumericDefault="100" PreviewKeyDown="SwitchDelay_PreviewKeyDown"/>
                                    </Grid>

                                    <Button Grid.Row="4" Content="Reset" Command="{Binding ResetCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="6,4" HorizontalAlignment="Stretch"/>
                                </Grid>
                            </GroupBox>

                            <!-- Middle/Right: ATK x DEF Slots -->
                            <Grid Grid.Column="2" HorizontalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="50" />
                                    <ColumnDefinition Width="110" />
                                </Grid.ColumnDefinitions>

                                <!-- DEF Slots -->
                                <StackPanel Grid.Column="0" Margin="0" VerticalAlignment="Center">
                                    <TextBlock Text="DEF Switch" Foreground="{DynamicResource AppSubtleBrush}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,0,10,8" />
                                    <StackPanel Margin="0">
                                        <Grid Margin="0,0,0,2" HorizontalAlignment="Right">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="30"/><ColumnDefinition Width="80"/></Grid.ColumnDefinitions>
                                            <Image Source="pack://application:,,,/Icons/ATKDEF/armor_head.png" Width="24" Height="24" Stretch="None" RenderOptions.BitmapScalingMode="NearestNeighbor" HorizontalAlignment="Center"/>
                                            <TextBox Grid.Column="1" Text="{Binding DefHead, Mode=TwoWay, Converter={StaticResource KeyToStringConverter}}" Style="{StaticResource KeyTextBoxStyle}" PreviewKeyDown="DefHead_PreviewKeyDown" Height="22"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,2" HorizontalAlignment="Right">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="30"/><ColumnDefinition Width="80"/></Grid.ColumnDefinitions>
                                            <Image Source="pack://application:,,,/Icons/ATKDEF/armor_body.png" Width="24" Height="24" Stretch="None" RenderOptions.BitmapScalingMode="NearestNeighbor" HorizontalAlignment="Center"/>
                                            <TextBox Grid.Column="1" Text="{Binding DefBody, Mode=TwoWay, Converter={StaticResource KeyToStringConverter}}" Style="{StaticResource KeyTextBoxStyle}" PreviewKeyDown="DefBody_PreviewKeyDown" Height="22"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,2" HorizontalAlignment="Right">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="30"/><ColumnDefinition Width="80"/></Grid.ColumnDefinitions>
                                            <Image Source="pack://application:,,,/Icons/ATKDEF/dagger.png" Width="24" Height="24" Stretch="None" RenderOptions.BitmapScalingMode="NearestNeighbor" HorizontalAlignment="Center"/>
                                            <TextBox Grid.Column="1" Text="{Binding DefWeapon, Mode=TwoWay, Converter={StaticResource KeyToStringConverter}}" Style="{StaticResource KeyTextBoxStyle}" PreviewKeyDown="DefWeapon_PreviewKeyDown" Height="22"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,2" HorizontalAlignment="Right">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="30"/><ColumnDefinition Width="80"/></Grid.ColumnDefinitions>
                                            <Image Source="pack://application:,,,/Icons/ATKDEF/armor_shield.png" Width="24" Height="24" Stretch="None" RenderOptions.BitmapScalingMode="NearestNeighbor" HorizontalAlignment="Center"/>
                                            <TextBox Grid.Column="1" Text="{Binding DefShield, Mode=TwoWay, Converter={StaticResource KeyToStringConverter}}" Style="{StaticResource KeyTextBoxStyle}" PreviewKeyDown="DefShield_PreviewKeyDown" Height="22"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,2" HorizontalAlignment="Right">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="30"/><ColumnDefinition Width="80"/></Grid.ColumnDefinitions>
                                            <Image Source="pack://application:,,,/Icons/ATKDEF/armor_robe.png" Width="24" Height="24" Stretch="None" RenderOptions.BitmapScalingMode="NearestNeighbor" HorizontalAlignment="Center"/>
                                            <TextBox Grid.Column="1" Text="{Binding DefGarment, Mode=TwoWay, Converter={StaticResource KeyToStringConverter}}" Style="{StaticResource KeyTextBoxStyle}" PreviewKeyDown="DefGarment_PreviewKeyDown" Height="22"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,2" HorizontalAlignment="Right">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="30"/><ColumnDefinition Width="80"/></Grid.ColumnDefinitions>
                                            <Image Source="pack://application:,,,/Icons/ATKDEF/armor_shoes.png" Width="24" Height="24" Stretch="None" RenderOptions.BitmapScalingMode="NearestNeighbor" HorizontalAlignment="Center"/>
                                            <TextBox Grid.Column="1" Text="{Binding DefShoes, Mode=TwoWay, Converter={StaticResource KeyToStringConverter}}" Style="{StaticResource KeyTextBoxStyle}" PreviewKeyDown="DefShoes_PreviewKeyDown" Height="22"/>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Divider -->
                                <Rectangle Grid.Column="1" Width="1" Fill="{DynamicResource AppBorderBrush}" Margin="0,15" HorizontalAlignment="Center"/>

                                <!-- ATK Slots -->
                                <StackPanel Grid.Column="2" Margin="0" VerticalAlignment="Center">
                                    <TextBlock Text="ATK Switch" Foreground="{DynamicResource AppDangerBrush}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Left" Margin="10,0,0,8" />
                                    <StackPanel Margin="0">
                                        <Grid Margin="0,0,0,2" HorizontalAlignment="Left">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="30"/></Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" Text="{Binding AtkHead, Mode=TwoWay, Converter={StaticResource KeyToStringConverter}}" Style="{StaticResource KeyTextBoxStyle}" PreviewKeyDown="AtkHead_PreviewKeyDown" Height="22"/>
                                            <Image Grid.Column="1" Source="pack://application:,,,/Icons/ATKDEF/armor_head.png" Width="24" Height="24" Stretch="None" RenderOptions.BitmapScalingMode="NearestNeighbor" HorizontalAlignment="Center"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,2" HorizontalAlignment="Left">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="30"/></Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" Text="{Binding AtkBody, Mode=TwoWay, Converter={StaticResource KeyToStringConverter}}" Style="{StaticResource KeyTextBoxStyle}" PreviewKeyDown="AtkBody_PreviewKeyDown" Height="22"/>
                                            <Image Grid.Column="1" Source="pack://application:,,,/Icons/ATKDEF/armor_body.png" Width="24" Height="24" Stretch="None" RenderOptions.BitmapScalingMode="NearestNeighbor" HorizontalAlignment="Center"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,2" HorizontalAlignment="Left">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="30"/></Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" Text="{Binding AtkWeapon, Mode=TwoWay, Converter={StaticResource KeyToStringConverter}}" Style="{StaticResource KeyTextBoxStyle}" PreviewKeyDown="AtkWeapon_PreviewKeyDown" Height="22"/>
                                            <Image Grid.Column="1" Source="pack://application:,,,/Icons/ATKDEF/dagger.png" Width="24" Height="24" Stretch="None" RenderOptions.BitmapScalingMode="NearestNeighbor" HorizontalAlignment="Center"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,2" HorizontalAlignment="Left">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="30"/></Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" Text="{Binding AtkShield, Mode=TwoWay, Converter={StaticResource KeyToStringConverter}}" Style="{StaticResource KeyTextBoxStyle}" PreviewKeyDown="AtkShield_PreviewKeyDown" Height="22"/>
                                            <Image Grid.Column="1" Source="pack://application:,,,/Icons/ATKDEF/armor_shield.png" Width="24" Height="24" Stretch="None" RenderOptions.BitmapScalingMode="NearestNeighbor" HorizontalAlignment="Center"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,2" HorizontalAlignment="Left">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="30"/></Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" Text="{Binding AtkGarment, Mode=TwoWay, Converter={StaticResource KeyToStringConverter}}" Style="{StaticResource KeyTextBoxStyle}" PreviewKeyDown="AtkGarment_PreviewKeyDown" Height="22"/>
                                            <Image Grid.Column="1" Source="pack://application:,,,/Icons/ATKDEF/armor_robe.png" Width="24" Height="24" Stretch="None" RenderOptions.BitmapScalingMode="NearestNeighbor" HorizontalAlignment="Center"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,2" HorizontalAlignment="Left">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="30"/></Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" Text="{Binding AtkShoes, Mode=TwoWay, Converter={StaticResource KeyToStringConverter}}" Style="{StaticResource KeyTextBoxStyle}" PreviewKeyDown="AtkShoes_PreviewKeyDown" Height="22"/>
                                            <Image Grid.Column="1" Source="pack://application:,,,/Icons/ATKDEF/armor_shoes.png" Width="24" Height="24" Stretch="None" RenderOptions.BitmapScalingMode="NearestNeighbor" HorizontalAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>
