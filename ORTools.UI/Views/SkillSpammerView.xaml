<UserControl x:Class="ORTools.UI.Views.SkillSpammerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:ORTools.UI.ViewModels" xmlns:helpers="clr-namespace:ORTools.UI.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="600"
             d:DataContext="{d:DesignInstance Type=vm:SkillSpammerViewModel}">

    <UserControl.Resources>
        <Style x:Key="SpammerCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="IsThreeState" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Cursor="Hand">
                            <Border x:Name="Bd" Width="16" Height="16" BorderBrush="#313338" BorderThickness="1" Background="White" CornerRadius="0" VerticalAlignment="Center">
                                <TextBlock x:Name="CheckMark" Text="✓" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Hidden" FontWeight="Bold" FontSize="12" Margin="0,-2,0,0"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0078D7"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#0078D7"/>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="CheckMark" Property="Text" Value="✓"/>
                                <Setter TargetName="CheckMark" Property="FontSize" Value="12"/>
                                <Setter TargetName="CheckMark" Property="Margin" Value="0,-2,0,0"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="{x:Null}">
                                <Setter TargetName="Bd" Property="Background" Value="#DB950D"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#DB950D"/>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="CheckMark" Property="Text" Value="-"/>
                                <Setter TargetName="CheckMark" Property="FontSize" Value="18"/>
                                <Setter TargetName="CheckMark" Property="Margin" Value="0,-4,0,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="SpammerKeyTemplate" DataType="{x:Type vm:SpammerKeyViewModel}">
            <CheckBox Style="{StaticResource SpammerCheckBoxStyle}"
                      IsChecked="{Binding IsCheckedState, Mode=TwoWay}"
                      VerticalAlignment="Center">
                <Image Source="{Binding ImagePath}" Height="24" Stretch="None" RenderOptions.BitmapScalingMode="NearestNeighbor" RenderOptions.EdgeMode="Aliased" VerticalAlignment="Center" Margin="4,0,0,0"/>
            </CheckBox>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="22,10,22,10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Keys Area -->
        <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,10,20,0" HorizontalAlignment="Stretch">

            <ItemsControl ItemsSource="{Binding FKeys}" ItemTemplate="{StaticResource SpammerKeyTemplate}">
                <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="9" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
            </ItemsControl>

            <Border Height="1" Background="{DynamicResource AppBorderBrush}" Margin="0,10,16,12" />

            <ItemsControl ItemsSource="{Binding NumKeys}" ItemTemplate="{StaticResource SpammerKeyTemplate}" Margin="0,0,0,19">
                <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="9" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
            </ItemsControl>

            <ItemsControl ItemsSource="{Binding QKeys}" ItemTemplate="{StaticResource SpammerKeyTemplate}" Margin="0,0,0,19">
                <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="9" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
            </ItemsControl>

            <ItemsControl ItemsSource="{Binding AKeys}" ItemTemplate="{StaticResource SpammerKeyTemplate}" Margin="0,0,0,19">
                <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="9" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
            </ItemsControl>

            <ItemsControl ItemsSource="{Binding ZKeys}" ItemTemplate="{StaticResource SpammerKeyTemplate}">
                <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="9" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
            </ItemsControl>

        </StackPanel>

        <!-- Right Panel (Legend) -->
        <StackPanel Grid.Column="1" Grid.Row="0" Width="120" HorizontalAlignment="Right" VerticalAlignment="Top">
            <GroupBox Header="Legend" Margin="0,0,0,10" Foreground="{DynamicResource AppTextBrush}" BorderBrush="{DynamicResource AppBorderBrush}">
                <StackPanel Margin="5">
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <CheckBox Style="{StaticResource SpammerCheckBoxStyle}" IsChecked="True" IsHitTestVisible="False" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="With click" VerticalAlignment="Center" Foreground="{DynamicResource AppTextBrush}" Width="55"/>
                        <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                            <Canvas Width="16" Height="16">
                                <Path Fill="{DynamicResource AppDangerBrush}" Data="M 8,0 A 5,5 0 0,0 3,5 L 3,7 L 8,7 Z" />
                                <Path Stroke="{DynamicResource AppTextBrush}" StrokeThickness="1.5" Fill="Transparent" Data="M 3,5 A 5,5 0 0,1 13,5 L 13,11 A 5,5 0 0,1 3,11 Z" />
                                <Line X1="8" Y1="0" X2="8" Y2="7" Stroke="{DynamicResource AppTextBrush}" StrokeThickness="1.5" />
                                <Line X1="3" Y1="7" X2="13" Y2="7" Stroke="{DynamicResource AppTextBrush}" StrokeThickness="1.5" />
                            </Canvas>
                        </Viewbox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <CheckBox Style="{StaticResource SpammerCheckBoxStyle}" IsChecked="{x:Null}" IsHitTestVisible="False" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="No click" VerticalAlignment="Center" Foreground="{DynamicResource AppTextBrush}" Width="55"/>
                        <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                            <Canvas Width="16" Height="16">
                                <Path Stroke="{DynamicResource AppTextBrush}" StrokeThickness="1.5" Fill="Transparent" Data="M 3,5 A 5,5 0 0,1 13,5 L 13,11 A 5,5 0 0,1 3,11 Z" />
                                <Line X1="8" Y1="0" X2="8" Y2="7" Stroke="{DynamicResource AppTextBrush}" StrokeThickness="1.5" />
                                <Line X1="3" Y1="7" X2="13" Y2="7" Stroke="{DynamicResource AppTextBrush}" StrokeThickness="1.5" />
                                <Line X1="1" Y1="1" X2="15" Y2="15" Stroke="{DynamicResource AppDangerBrush}" StrokeThickness="2" StrokeEndLineCap="Round" StrokeStartLineCap="Round"/>
                            </Canvas>
                        </Viewbox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <CheckBox Style="{StaticResource SpammerCheckBoxStyle}" IsChecked="False" IsHitTestVisible="False" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Disabled" VerticalAlignment="Center" Foreground="{DynamicResource AppTextBrush}" Width="55"/>
                        <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                            <Canvas Width="16" Height="16">
                                <Ellipse Canvas.Left="1" Canvas.Top="1" Width="14" Height="14" Stroke="{DynamicResource AppDangerBrush}" StrokeThickness="2" Fill="Transparent"/>
                                <Line X1="3.5" Y1="12.5" X2="12.5" Y2="3.5" Stroke="{DynamicResource AppDangerBrush}" StrokeThickness="2" />
                            </Canvas>
                        </Viewbox>
                    </StackPanel>
                </StackPanel>
            </GroupBox>
        </StackPanel>

        <Button Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="0"
                Command="{Binding OpenQuestLinkCommand}"
                Cursor="Hand"
                Margin="0,0,0,0"
                Padding="0"
                BorderThickness="0"
                Background="Transparent"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom">
            <Image Source="{Binding QuestImageSource}" Stretch="None" RenderOptions.BitmapScalingMode="NearestNeighbor" RenderOptions.EdgeMode="Aliased" />
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="Transparent">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- Bottom Panel (Key Config & Delay) -->
        <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,10,0,0" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Key Config" Margin="0,0,20,0" Foreground="{DynamicResource AppTextBrush}" BorderBrush="{DynamicResource AppBorderBrush}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                    <StackPanel Orientation="Horizontal" Margin="0,0,40,0">
                        <CheckBox Content="Mouse Flick" IsChecked="{Binding MouseFlick}" Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                            <Canvas Width="16" Height="16">
                                <Polygon Points="4,1  1,7  3,7  3,15  5,15  5,7  7,7" Fill="{DynamicResource AppTextBrush}" />
                                <Polygon Points="12,15  9,9  11,9  11,1  13,1  13,9  15,9" Fill="{DynamicResource AppTextBrush}" />
                            </Canvas>
                        </Viewbox>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,40,0">
                        <CheckBox Content="No Shift" IsChecked="{Binding NoShift}" Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <Viewbox Width="20" Height="14" VerticalAlignment="Center">
                            <Canvas Width="20" Height="14">
                                <Rectangle Width="20" Height="14" RadiusX="3" RadiusY="3" Stroke="{DynamicResource AppTextBrush}" StrokeThickness="1.5" Fill="Transparent" />
                                <Polygon Points="10,3  6,8  8.5,8  8.5,11  11.5,11  11.5,8  14,8" Fill="{DynamicResource AppTextBrush}" />
                            </Canvas>
                        </Viewbox>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <CheckBox Content="Toggle Mode" IsChecked="{Binding ToggleMode}" Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox Text="{Binding ToggleModeKey, Mode=TwoWay, Converter={StaticResource KeyToStringConverter}}"
                                 PreviewKeyDown="ToggleModeKey_PreviewKeyDown" ToolTip="Press a key to assign"
                                 Style="{StaticResource KeyTextBoxStyle}" HorizontalAlignment="Left" />
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Grid.Column="1" Header="Spammer Delay" Foreground="{DynamicResource AppTextBrush}" BorderBrush="{DynamicResource AppBorderBrush}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="10,5">
                    <TextBox Text="{Binding SpammerDelay, UpdateSourceTrigger=PropertyChanged, Delay=500}"
                             helpers:InputHelper.IsNumericInput="True" helpers:InputHelper.NumericDefault="50"
                             PreviewKeyDown="SpammerDelay_PreviewKeyDown"
                             Style="{StaticResource NumericTextBoxStyle}" Width="50" />
                    <TextBlock Text="ms" VerticalAlignment="Center" Margin="5,0,0,0" Foreground="{DynamicResource AppTextBrush}"/>
                </StackPanel>
            </GroupBox>
        </Grid>

        <!-- Banner and Links -->
        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,10,0,0" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Image Source="pack://application:,,,/Assets/Banners/server_banner.png" Height="106" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor" RenderOptions.EdgeMode="Aliased" />
            <Grid Margin="0,5,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- MR Links -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock><Hyperlink NavigateUri="https://osro.mr" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource AppLinkBrush}" TextDecorations="None">Website</Hyperlink></TextBlock>
                    <TextBlock Margin="35,0"><Hyperlink NavigateUri="https://wiki.osro.mr" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource AppLinkBrush}" TextDecorations="None">Wiki</Hyperlink></TextBlock>
                    <TextBlock><Hyperlink NavigateUri="https://discord.com/invite/osro2" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource AppLinkBrush}" TextDecorations="None">Discord</Hyperlink></TextBlock>
                </StackPanel>

                <!-- HR Links -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock><Hyperlink NavigateUri="https://osro.gg" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource AppLinkBrush}" TextDecorations="None">Website</Hyperlink></TextBlock>
                    <TextBlock Margin="35,0"><Hyperlink NavigateUri="https://wiki.osro.gg" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource AppLinkBrush}" TextDecorations="None">Wiki</Hyperlink></TextBlock>
                    <TextBlock><Hyperlink NavigateUri="https://discord.com/invite/osro" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource AppLinkBrush}" TextDecorations="None">Discord</Hyperlink></TextBlock>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
