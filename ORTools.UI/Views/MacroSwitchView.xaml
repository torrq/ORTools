<UserControl x:Class="ORTools.UI.Views.MacroSwitchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:ORTools.UI.ViewModels"
             xmlns:helpers="clr-namespace:ORTools.UI.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance vm:MacroSwitchViewModel}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding Rows}" Margin="10">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="{DynamicResource AppSurfaceAltBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="4" Margin="0,0,0,8" Padding="10,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Left Side: Trigger -->
                            <StackPanel Grid.Column="0" Width="70" Margin="0,0,10,0" VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource S.MacroSwitch.TriggerKey}" Foreground="{DynamicResource AppSubtleBrush}" FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,4" />
                                <TextBox Text="{Binding TriggerKey, Mode=TwoWay, Converter={StaticResource KeyToStringConverter}}"
                                         Style="{StaticResource KeyTextBoxStyle}" 
                                         PreviewKeyDown="TriggerKey_PreviewKeyDown"
                                         HorizontalAlignment="Stretch" Margin="0,0,0,10" Height="22"/>
                                <Button Content="{DynamicResource S.MacroSwitch.Reset}" Command="{Binding ResetRowCommand}" Style="{StaticResource DangerButtonStyle}" Padding="6,2"/>
                            </StackPanel>

                            <!-- Right Side: Centered Labels & Steps -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,6">
                                <!-- Labels -->
                                <StackPanel VerticalAlignment="Bottom" Margin="0,0,4,0">
                                    <TextBlock Text="Key" Foreground="{DynamicResource AppSubtleBrush}" FontSize="10" Height="22" Margin="0,0,0,6" VerticalAlignment="Center" TextAlignment="Right"/>
                                    <TextBlock Text="Delay" Foreground="{DynamicResource AppSubtleBrush}" FontSize="10" Height="22" Margin="0,0,0,6" VerticalAlignment="Center" TextAlignment="Right"/>
                                    <TextBlock Text="Click" Foreground="{DynamicResource AppSubtleBrush}" FontSize="10" Height="16" VerticalAlignment="Center" TextAlignment="Right"/>
                                </StackPanel>

                                <!-- Steps -->
                                <ItemsControl ItemsSource="{Binding Steps}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Width="60" Margin="4,0,0,0">
                                            <TextBox Text="{Binding Key, Mode=TwoWay, Converter={StaticResource KeyToStringConverter}}"
                                                     Style="{StaticResource KeyTextBoxStyle}" Height="22"
                                                     PreviewKeyDown="StepKey_PreviewKeyDown"
                                                     Margin="0,0,0,6" />
                                            
                                            <TextBox Text="{Binding Delay, UpdateSourceTrigger=PropertyChanged, Delay=250}"
                                                     Style="{StaticResource NumericTextBoxStyle}" Height="22"
                                                     helpers:InputHelper.IsNumericInput="True" helpers:InputHelper.NumericDefault="100"
                                                     PreviewKeyDown="StepDelay_PreviewKeyDown"
                                                     Margin="0,0,0,6"/>

                                            <CheckBox IsChecked="{Binding Click}" HorizontalAlignment="Center" Height="16"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>
