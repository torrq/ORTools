<UserControl x:Class="ORTools.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:ORTools.UI.ViewModels"
             xmlns:helpers="clr-namespace:ORTools.UI.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance vm:SettingsViewModel}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10">
            <GroupBox Header="Profile Settings" Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,10">
                <StackPanel Margin="5">
                    <CheckBox Margin="0,0,0,8" Content="Pause when in town" IsChecked="{Binding StopBuffsCity}" Foreground="{DynamicResource AppTextBrush}"/>
                    <CheckBox Margin="0,0,0,8" Content="Sounds on" IsChecked="{Binding SoundEnabled}" Foreground="{DynamicResource AppTextBrush}"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Global Settings" Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,10">
                <StackPanel Margin="5">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="App Theme" Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1" ItemsSource="{Binding ThemeModes}" SelectedItem="{Binding Theme}" 
                                  Background="{DynamicResource AppInputBrush}" Foreground="Black" 
                                  BorderBrush="{DynamicResource AppInputBorderBrush}" Height="24" FontSize="12" />
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="60" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Song Rows" Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Text="{Binding SongRows, UpdateSourceTrigger=PropertyChanged, Delay=500}"
                                 helpers:InputHelper.IsNumericInput="True"
                                 PreviewKeyDown="SongRows_PreviewKeyDown"
                                 TextChanged="RowsTextBox_TextChanged"
                                 Style="{StaticResource NumericTextBoxStyle}" HorizontalAlignment="Left" />
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Macro Switch Rows" Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Text="{Binding MacroSwitchRows, UpdateSourceTrigger=PropertyChanged, Delay=500}"
                                 helpers:InputHelper.IsNumericInput="True"
                                 PreviewKeyDown="MacroSwitchRows_PreviewKeyDown"
                                 TextChanged="RowsTextBox_TextChanged"
                                 Style="{StaticResource NumericTextBoxStyle}" HorizontalAlignment="Left" />
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="ATK x DEF Rows" Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Text="{Binding AtkDefRows, UpdateSourceTrigger=PropertyChanged, Delay=500}"
                                 helpers:InputHelper.IsNumericInput="True"
                                 PreviewKeyDown="AtkDefRows_PreviewKeyDown"
                                 TextChanged="RowsTextBox_TextChanged"
                                 Style="{StaticResource NumericTextBoxStyle}" HorizontalAlignment="Left" />
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Default Toggle Key" Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Text="{Binding DefaultToggleStateKey, Mode=TwoWay, Converter={StaticResource KeyToStringConverter}}"
                                 PreviewKeyDown="DefaultToggleKey_PreviewKeyDown"
                                 Style="{StaticResource KeyTextBoxStyle}" HorizontalAlignment="Left" />
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <CheckBox Content="Debug Mode" IsChecked="{Binding DebugMode}" Foreground="{DynamicResource AppTextBrush}" Margin="0,0,10,0"/>
                        <CheckBox Content="Show Log" IsChecked="{Binding DebugModeShowLog}" Foreground="{DynamicResource AppTextBrush}" IsEnabled="{Binding DebugMode}"/>
                    </StackPanel>

                    <CheckBox Margin="0,0,0,8" Content="Disable Systray Icon" IsChecked="{Binding DisableSystray}" Foreground="{DynamicResource AppTextBrush}"/>
                    <CheckBox Margin="0,0,0,8" Content="Pause when chatting" IsChecked="{Binding PauseWhenChatting}" Foreground="{DynamicResource AppTextBrush}"/>
                    <CheckBox Margin="0,0,0,8" Content="Pause when dead" IsChecked="{Binding PauseWhenDead}" Foreground="{DynamicResource AppTextBrush}"/>

                    <GroupBox Header="Auto-Off" Foreground="{DynamicResource AppTextBrush}" Margin="0,5,0,0">
                        <StackPanel Margin="5">
                            <CheckBox Margin="0,0,0,8" Content="Start timer on enable" IsChecked="{Binding StartAutoOffTimerOnEnable}" Foreground="{DynamicResource AppTextBrush}"/>
                            <CheckBox Margin="0,0,0,0" Content="Stop timer on disable" IsChecked="{Binding ClearAutoOffTimerOnDisable}" Foreground="{DynamicResource AppTextBrush}"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
