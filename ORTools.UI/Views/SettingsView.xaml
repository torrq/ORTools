<UserControl x:Class="ORTools.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:ORTools.UI.ViewModels"
             xmlns:helpers="clr-namespace:ORTools.UI.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance vm:SettingsViewModel}">
    <TabControl Background="Transparent" BorderThickness="0">
        <TabItem Header="Main">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10">
                    <GroupBox Header="Profile Settings" Foreground="{StaticResource AppTextBrush}" Margin="0,0,0,10">
                        <StackPanel Margin="5">
                            <CheckBox Margin="0,0,0,8" Content="Pause when in town" IsChecked="{Binding StopBuffsCity}" Foreground="{StaticResource AppTextBrush}"/>
                            <CheckBox Margin="0,0,0,8" Content="Sounds on" IsChecked="{Binding SoundEnabled}" Foreground="{StaticResource AppTextBrush}"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Global Settings" Foreground="{StaticResource AppTextBrush}" Margin="0,0,0,10">
                        <StackPanel Margin="5">
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="60" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Song Rows" Foreground="{StaticResource AppTextBrush}" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Text="{Binding SongRows, UpdateSourceTrigger=PropertyChanged, Delay=500}" TextAlignment="Center"
                                         helpers:InputHelper.IsNumericInput="True"
                                         PreviewKeyDown="SongRows_PreviewKeyDown"/>
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="60" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Macro Switch Rows" Foreground="{StaticResource AppTextBrush}" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Text="{Binding MacroSwitchRows, UpdateSourceTrigger=PropertyChanged, Delay=500}" TextAlignment="Center"
                                         helpers:InputHelper.IsNumericInput="True"
                                         PreviewKeyDown="MacroSwitchRows_PreviewKeyDown"/>
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="60" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Default Toggle Key" Foreground="{StaticResource AppTextBrush}" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Text="{Binding DefaultToggleStateKey}" TextAlignment="Center"
                                         PreviewKeyDown="DefaultToggleKey_PreviewKeyDown"/>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <CheckBox Content="Debug Mode" IsChecked="{Binding DebugMode}" Foreground="{StaticResource AppTextBrush}" Margin="0,0,10,0"/>
                                <CheckBox Content="Show Log" IsChecked="{Binding DebugModeShowLog}" Foreground="{StaticResource AppTextBrush}" IsEnabled="{Binding DebugMode}"/>
                            </StackPanel>

                            <CheckBox Margin="0,0,0,8" Content="Disable Systray Icon" IsChecked="{Binding DisableSystray}" Foreground="{StaticResource AppTextBrush}"/>
                            <CheckBox Margin="0,0,0,8" Content="Pause when chatting" IsChecked="{Binding PauseWhenChatting}" Foreground="{StaticResource AppTextBrush}"/>
                            <CheckBox Margin="0,0,0,8" Content="Pause when dead" IsChecked="{Binding PauseWhenDead}" Foreground="{StaticResource AppTextBrush}"/>

                            <GroupBox Header="Auto-Off" Foreground="{StaticResource AppTextBrush}" Margin="0,5,0,0">
                                <StackPanel Margin="5">
                                    <CheckBox Margin="0,0,0,8" Content="Start timer on enable" IsChecked="{Binding StartAutoOffTimerOnEnable}" Foreground="{StaticResource AppTextBrush}"/>
                                    <CheckBox Margin="0,0,0,0" Content="Stop timer on disable" IsChecked="{Binding ClearAutoOffTimerOnDisable}" Foreground="{StaticResource AppTextBrush}"/>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
    </TabControl>
</UserControl>
