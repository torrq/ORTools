<UserControl x:Class="ORTools.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:ORTools.UI.ViewModels"
             xmlns:helpers="clr-namespace:ORTools.UI.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance vm:SettingsViewModel}">
    <UserControl.Resources>
        <helpers:ThemeModeToStringConverter x:Key="ThemeModeToStringConverter" />

        <Style x:Key="SidebarTabControlStyle" TargetType="TabControl">
            <Setter Property="TabStripPlacement" Value="Left"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" Padding="0,15,0,15" Background="Transparent">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel IsItemsHost="True"/>
                                </ScrollViewer>
                            </Border>

                            <ContentPresenter Grid.Column="1" ContentSource="SelectedContent"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarTabItemStyle" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="BorderThickness" Value="4,0,0,0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AppSurfaceAltBrush}"/>
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
                                <Setter Property="Opacity" Value="1.0"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource AppPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <TabControl Style="{StaticResource SidebarTabControlStyle}" TabStripPlacement="Left">

        <!-- Per-Profile Settings -->
        <TabItem Style="{StaticResource SidebarTabItemStyle}">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE77B;" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Per-Profile Settings" FontSize="14" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </StackPanel>
            </TabItem.Header>
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,15,0,0">
                <StackPanel Margin="40,10" Orientation="Horizontal" VerticalAlignment="Top">
                    <GroupBox Foreground="{DynamicResource AppTextBrush}" Margin="0,0,40,15" MaxWidth="500" HorizontalAlignment="Left" Width="190">
                        <GroupBox.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8F2;" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Profile Behavior" VerticalAlignment="Center"/>
                            </StackPanel>
                        </GroupBox.Header>
                        <StackPanel Margin="10">
                            <CheckBox Margin="0,0,0,12" Content="Pause when in town" IsChecked="{Binding StopBuffsCity}" Foreground="{DynamicResource AppTextBrush}"/>
                            <CheckBox Margin="0,0,0,0" Content="Sounds on" IsChecked="{Binding SoundEnabled}" Foreground="{DynamicResource AppTextBrush}"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,15" MaxWidth="500" HorizontalAlignment="Left" Width="190">
                        <GroupBox.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE916;" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Auto-Off Options" VerticalAlignment="Center"/>
                            </StackPanel>
                        </GroupBox.Header>
                        <StackPanel Margin="10">
                            <CheckBox Margin="0,0,0,12" Content="Start timer on enable" IsChecked="{Binding StartAutoOffTimerOnEnable}" Foreground="{DynamicResource AppTextBrush}"/>
                            <CheckBox Margin="0,0,0,0" Content="Stop timer on disable" IsChecked="{Binding ClearAutoOffTimerOnDisable}" Foreground="{DynamicResource AppTextBrush}"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- Interface -->
        <TabItem Style="{StaticResource SidebarTabItemStyle}">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7F4;" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Interface" FontSize="14" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </StackPanel>
            </TabItem.Header>
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,15,0,0">
                <StackPanel Margin="40,10">
                    <GroupBox Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,15" MaxWidth="500" HorizontalAlignment="Left">
                        <GroupBox.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7F4;" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Interface Layout" VerticalAlignment="Center"/>
                            </StackPanel>
                        </GroupBox.Header>
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="App Theme" Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" Margin="0,0,0,12" />
                            <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding ThemeModes}" SelectedItem="{Binding Theme}" 
                                      Background="{DynamicResource AppInputBrush}" Foreground="Black" 
                                      BorderBrush="{DynamicResource AppInputBorderBrush}" Height="28" FontSize="14" HorizontalAlignment="Stretch" Margin="0,0,0,12">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource ThemeModeToStringConverter}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBlock Grid.Row="1" Text="Song Rows" Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" Margin="0,0,0,12" />
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SongRows, UpdateSourceTrigger=PropertyChanged, Delay=500}"
                                     helpers:InputHelper.IsNumericInput="True"
                                     PreviewKeyDown="SongRows_PreviewKeyDown"
                                     TextChanged="RowsTextBox_TextChanged"
                                     Style="{StaticResource NumericTextBoxStyle}" HorizontalAlignment="Right" Height="28" FontSize="14" Margin="0,0,0,12"/>

                            <TextBlock Grid.Row="2" Text="Macro Switch Rows" Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" Margin="0,0,0,12" />
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding MacroSwitchRows, UpdateSourceTrigger=PropertyChanged, Delay=500}"
                                     helpers:InputHelper.IsNumericInput="True"
                                     PreviewKeyDown="MacroSwitchRows_PreviewKeyDown"
                                     TextChanged="RowsTextBox_TextChanged"
                                     Style="{StaticResource NumericTextBoxStyle}" HorizontalAlignment="Right" Height="28" FontSize="14" Margin="0,0,0,12"/>

                            <TextBlock Grid.Row="3" Text="ATK x DEF Rows" Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" Margin="0,0,0,12" />
                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding AtkDefRows, UpdateSourceTrigger=PropertyChanged, Delay=500}"
                                     helpers:InputHelper.IsNumericInput="True"
                                     PreviewKeyDown="AtkDefRows_PreviewKeyDown"
                                     TextChanged="RowsTextBox_TextChanged"
                                     Style="{StaticResource NumericTextBoxStyle}" HorizontalAlignment="Right" Height="28" FontSize="14" Margin="0,0,0,12"/>

                            <TextBlock Grid.Row="4" Text="Default Toggle Key" Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
                            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding DefaultToggleStateKey, Mode=TwoWay, Converter={StaticResource KeyToStringConverter}}"
                                     PreviewKeyDown="DefaultToggleKey_PreviewKeyDown"
                                     Style="{StaticResource KeyTextBoxStyle}" HorizontalAlignment="Right" Height="28" FontSize="14"/>
                        </Grid>
                    </GroupBox>

                    <GroupBox Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,15" MaxWidth="500" HorizontalAlignment="Left" Width="252">
                        <GroupBox.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xEE40;" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="System Tray" VerticalAlignment="Center"/>
                            </StackPanel>
                        </GroupBox.Header>
                        <StackPanel Margin="10">
                            <CheckBox x:Name="CbDisableSystray" Margin="0,4,0,4" Content="Disable Systray Icon" IsChecked="{Binding DisableSystray}" Foreground="{DynamicResource AppTextBrush}"/>
                            <CheckBox Content="Minimize to systray" IsChecked="{Binding MinimizeToSystray}" Foreground="{DynamicResource AppTextBrush}" Margin="0,4,0,4">
                                <CheckBox.Style>
                                    <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DisableSystray}" Value="True">
                                                <Setter Property="IsEnabled" Value="False"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </CheckBox.Style>
                            </CheckBox>
                            <CheckBox Content="Close to systray" IsChecked="{Binding CloseToSystray}" Foreground="{DynamicResource AppTextBrush}" Margin="0,4,0,4">
                                <CheckBox.Style>
                                    <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DisableSystray}" Value="True">
                                                <Setter Property="IsEnabled" Value="False"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </CheckBox.Style>
                            </CheckBox>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- Behavior -->
        <TabItem Style="{StaticResource SidebarTabItemStyle}">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE909;" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Behavior" FontSize="14" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </StackPanel>
            </TabItem.Header>
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,15,0,0">
                <StackPanel Margin="40,10">
                    <GroupBox Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,15" MaxWidth="500" HorizontalAlignment="Left">
                        <GroupBox.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE909;" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="General Behavior" VerticalAlignment="Center"/>
                            </StackPanel>
                        </GroupBox.Header>
                        <StackPanel Margin="10">
                            <CheckBox Margin="0,0,0,12" Content="Pause when chatting" IsChecked="{Binding PauseWhenChatting}" Foreground="{DynamicResource AppTextBrush}"/>
                            <CheckBox Margin="0,0,0,0" Content="Pause when dead" IsChecked="{Binding PauseWhenDead}" Foreground="{DynamicResource AppTextBrush}"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- Developer -->
        <TabItem Style="{StaticResource SidebarTabItemStyle}">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xEBE8;" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Developer" FontSize="14" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </StackPanel>
            </TabItem.Header>
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,15,0,0">
                <StackPanel Margin="40,10">
                    <GroupBox Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,15" MaxWidth="600" HorizontalAlignment="Left">
                        <GroupBox.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xEBE8;" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Developer Tools" VerticalAlignment="Center"/>
                            </StackPanel>
                        </GroupBox.Header>
                        <StackPanel Margin="10">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <CheckBox Content="Debug Mode" IsChecked="{Binding DebugMode}" Foreground="{DynamicResource AppTextBrush}" Margin="0,0,20,0"/>
                                <CheckBox Content="Debug View" IsChecked="{Binding DebugView}" Foreground="{DynamicResource AppTextBrush}" IsEnabled="{Binding DebugMode}" Margin="0,0,20,0"/>
                                <CheckBox Content="Client Log" IsChecked="{Binding DebugClientLog}" Foreground="{DynamicResource AppTextBrush}" IsEnabled="{Binding DebugMode}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12" IsEnabled="{Binding DebugMode}">
                                <TextBlock Text="Debug View Height:" VerticalAlignment="Center" Foreground="{DynamicResource AppTextBrush}" Margin="0,0,10,0"/>
                                <TextBox Text="{Binding DebugViewHeight, UpdateSourceTrigger=PropertyChanged}" Width="50" Style="{StaticResource NumericTextBoxStyle}"/>
                            </StackPanel>
                            <CheckBox Content="Allow resizing window" IsChecked="{Binding AllowResizingWindow}" Foreground="{DynamicResource AppTextBrush}"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

    </TabControl>
</UserControl>
