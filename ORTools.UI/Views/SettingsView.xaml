<UserControl x:Class="ORTools.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:ORTools.UI.ViewModels"
             xmlns:helpers="clr-namespace:ORTools.UI.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance vm:SettingsViewModel}">
    <TabControl Style="{StaticResource SubTabControlStyle}">
        <TabItem Header="Profile Settings" Style="{StaticResource SubTabItemStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,15,0,0">
                <StackPanel Margin="40,10">
                    <GroupBox Header="Profile Behavior" Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,10" MaxWidth="400" HorizontalAlignment="Center">
                        <StackPanel Margin="10">
                            <CheckBox Margin="0,0,0,12" Content="Pause when in town" IsChecked="{Binding StopBuffsCity}" Foreground="{DynamicResource AppTextBrush}"/>
                            <CheckBox Margin="0,0,0,0" Content="Sounds on" IsChecked="{Binding SoundEnabled}" Foreground="{DynamicResource AppTextBrush}"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="Global Settings" Style="{StaticResource SubTabItemStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,15,0,0">
                <Grid Margin="40,10" HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Left Column -->
                    <StackPanel Grid.Column="0">
                        <GroupBox Header="Interface" Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,15">
                            <StackPanel Margin="10">
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="App Theme" Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
                                    <ComboBox Grid.Column="1" ItemsSource="{Binding ThemeModes}" SelectedItem="{Binding Theme}" 
                                              Background="{DynamicResource AppInputBrush}" Foreground="Black" 
                                              BorderBrush="{DynamicResource AppInputBorderBrush}" Height="28" FontSize="14" />
                                </Grid>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Song Rows" Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
                                    <TextBox Grid.Column="1" Text="{Binding SongRows, UpdateSourceTrigger=PropertyChanged, Delay=500}"
                                             helpers:InputHelper.IsNumericInput="True"
                                             PreviewKeyDown="SongRows_PreviewKeyDown"
                                             TextChanged="RowsTextBox_TextChanged"
                                             Style="{StaticResource NumericTextBoxStyle}" HorizontalAlignment="Stretch" Height="28" FontSize="14"/>
                                </Grid>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Macro Switch Rows" Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
                                    <TextBox Grid.Column="1" Text="{Binding MacroSwitchRows, UpdateSourceTrigger=PropertyChanged, Delay=500}"
                                             helpers:InputHelper.IsNumericInput="True"
                                             PreviewKeyDown="MacroSwitchRows_PreviewKeyDown"
                                             TextChanged="RowsTextBox_TextChanged"
                                             Style="{StaticResource NumericTextBoxStyle}" HorizontalAlignment="Stretch" Height="28" FontSize="14"/>
                                </Grid>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="ATK x DEF Rows" Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
                                    <TextBox Grid.Column="1" Text="{Binding AtkDefRows, UpdateSourceTrigger=PropertyChanged, Delay=500}"
                                             helpers:InputHelper.IsNumericInput="True"
                                             PreviewKeyDown="AtkDefRows_PreviewKeyDown"
                                             TextChanged="RowsTextBox_TextChanged"
                                             Style="{StaticResource NumericTextBoxStyle}" HorizontalAlignment="Stretch" Height="28" FontSize="14"/>
                                </Grid>
                                <Grid Margin="0,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Default Toggle Key" Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
                                    <TextBox Grid.Column="1" Text="{Binding DefaultToggleStateKey, Mode=TwoWay, Converter={StaticResource KeyToStringConverter}}"
                                             PreviewKeyDown="DefaultToggleKey_PreviewKeyDown"
                                             Style="{StaticResource KeyTextBoxStyle}" HorizontalAlignment="Stretch" Height="28" FontSize="14"/>
                                </Grid>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Behavior" Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,15">
                            <StackPanel Margin="10">
                                <CheckBox Margin="0,0,0,12" Content="Pause when chatting" IsChecked="{Binding PauseWhenChatting}" Foreground="{DynamicResource AppTextBrush}"/>
                                <CheckBox Margin="0,0,0,0" Content="Pause when dead" IsChecked="{Binding PauseWhenDead}" Foreground="{DynamicResource AppTextBrush}"/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>

                    <!-- Right Column -->
                    <StackPanel Grid.Column="2">
                        <GroupBox Header="System Tray" Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,15">
                            <StackPanel Margin="10">
                                <CheckBox x:Name="CbDisableSystray" Margin="0,0,0,12" Content="Disable Systray Icon" IsChecked="{Binding DisableSystray}" Foreground="{DynamicResource AppTextBrush}"/>
                                
                                <StackPanel Margin="20,0,0,0">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="IsEnabled" Value="True"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsChecked, ElementName=CbDisableSystray}" Value="True">
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                    <Setter Property="Opacity" Value="0.5"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <CheckBox Margin="0,0,0,12" Content="Minimize to systray" IsChecked="{Binding MinimizeToSystray}" Foreground="{DynamicResource AppTextBrush}"/>
                                    <CheckBox Margin="0,0,0,0" Content="Close to systray" IsChecked="{Binding CloseToSystray}" Foreground="{DynamicResource AppTextBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Auto-Off" Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,15">
                            <StackPanel Margin="10">
                                <CheckBox Margin="0,0,0,12" Content="Start timer on enable" IsChecked="{Binding StartAutoOffTimerOnEnable}" Foreground="{DynamicResource AppTextBrush}"/>
                                <CheckBox Margin="0,0,0,0" Content="Stop timer on disable" IsChecked="{Binding ClearAutoOffTimerOnDisable}" Foreground="{DynamicResource AppTextBrush}"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Developer" Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,15">
                            <StackPanel Margin="10">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <CheckBox Content="Debug Mode" IsChecked="{Binding DebugMode}" Foreground="{DynamicResource AppTextBrush}" Margin="0,0,20,0"/>
                                    <CheckBox Content="Debug Client Log" IsChecked="{Binding DebugClientLog}" Foreground="{DynamicResource AppTextBrush}" IsEnabled="{Binding DebugMode}"/>
                                </StackPanel>
                                <CheckBox Content="Allow resizing window" IsChecked="{Binding AllowResizingWindow}" Foreground="{DynamicResource AppTextBrush}"/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>

                </Grid>
            </ScrollViewer>
        </TabItem>
    </TabControl>
</UserControl>
