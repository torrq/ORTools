<UserControl x:Class="ORTools.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:ORTools.UI.ViewModels"
             xmlns:helpers="clr-namespace:ORTools.UI.Helpers"
             xmlns:views="clr-namespace:ORTools.UI.Views"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance vm:SettingsViewModel}"
             FontSize="13">
    <UserControl.Resources>
        <helpers:ThemeModeToStringConverter x:Key="ThemeModeToStringConverter" />

        <Style x:Key="SidebarTabControlStyle" TargetType="TabControl">
            <Setter Property="TabStripPlacement" Value="Left"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" Padding="0,15,0,15" Background="Transparent">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel IsItemsHost="True"/>
                                </ScrollViewer>
                            </Border>

                            <ContentPresenter Grid.Column="1" ContentSource="SelectedContent"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarTabItemStyle" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="BorderThickness" Value="4,0,0,0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                Cursor="Hand">
                            <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AppSurfaceAltBrush}"/>
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
                                <Setter Property="Opacity" Value="1.0"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource AppPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <TabControl Style="{StaticResource SidebarTabControlStyle}" TabStripPlacement="Left">

        <!-- Per-Profile Settings -->
        <TabItem Style="{StaticResource SidebarTabItemStyle}">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="pack://application:,,,/Fonts/#lucide" Text="&#xE19F;" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource S.Settings.PerProfileTab}" FontSize="14" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </StackPanel>
            </TabItem.Header>
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="20">
                <Grid VerticalAlignment="Top">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <GroupBox Grid.Column="0" Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,20">
                        <GroupBox.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="pack://application:,,,/Fonts/#lucide" Text="&#xE1B4;" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource S.Settings.ProfileBehavior}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            </StackPanel>
                        </GroupBox.Header>
                        <StackPanel Margin="10">
                            <CheckBox x:Name="CbPauseInTown" Margin="0,0,0,6" Content="{DynamicResource S.Settings.PauseInTown}" IsChecked="{Binding StopBuffsCity}" Foreground="{DynamicResource AppTextBrush}"/>
                            <CheckBox Content="{DynamicResource S.Settings.SoundsOn}" IsChecked="{Binding SoundEnabled}" Foreground="{DynamicResource AppTextBrush}"/>
                        </StackPanel>
                    </GroupBox>


                </Grid>
            </ScrollViewer>
        </TabItem>

        <!-- Interface -->
        <TabItem Style="{StaticResource SidebarTabItemStyle}">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="pack://application:,,,/Fonts/#lucide" Text="&#xE11D;" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource S.Settings.Interface}" FontSize="14" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </StackPanel>
            </TabItem.Header>
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="20">
                <StackPanel>
                    <GroupBox Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,20">
                        <GroupBox.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="pack://application:,,,/Fonts/#lucide" Text="&#xE11D;" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource S.Settings.InterfaceLayout}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            </StackPanel>
                        </GroupBox.Header>
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="{DynamicResource S.Settings.Language}" Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" Margin="0,0,0,6" />
                            <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding Languages}" SelectedItem="{Binding Language}"
                                      Background="{DynamicResource AppInputBrush}" Foreground="Black"
                                      BorderBrush="{DynamicResource AppInputBorderBrush}" FontSize="14" HorizontalAlignment="Stretch" Margin="0,0,0,6">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource LanguageToStringConverter}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBlock Grid.Row="1" Text="{DynamicResource S.Settings.AppTheme}" Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" Margin="0,0,0,6" />
                            <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding ThemeModes}" SelectedItem="{Binding Theme}"
                                      Background="{DynamicResource AppInputBrush}" Foreground="Black"
                                      BorderBrush="{DynamicResource AppInputBorderBrush}" FontSize="14" HorizontalAlignment="Stretch" Margin="0,0,0,6">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource ThemeModeToStringConverter}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBlock Grid.Row="2" Text="{DynamicResource S.Settings.SongRows}" Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" Margin="0,0,0,6" />
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SongRows, UpdateSourceTrigger=PropertyChanged, Delay=500}"
                                     helpers:InputHelper.IsNumericInput="True"
                                     helpers:InputHelper.NumericMax="100"
                                     helpers:InputHelper.NumericMin="1"
                                     PreviewKeyDown="SongRows_PreviewKeyDown"
                                     TextChanged="RowsTextBox_TextChanged"
                                     Style="{StaticResource NumericTextBoxStyle}" HorizontalAlignment="Right" FontSize="14" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="3" Text="{DynamicResource S.Settings.MacroSwitchRows}" Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" Margin="0,0,0,6" />
                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding MacroSwitchRows, UpdateSourceTrigger=PropertyChanged, Delay=500}"
                                     helpers:InputHelper.IsNumericInput="True"
                                     helpers:InputHelper.NumericMax="100"
                                     helpers:InputHelper.NumericMin="1"
                                     PreviewKeyDown="MacroSwitchRows_PreviewKeyDown"
                                     TextChanged="RowsTextBox_TextChanged"
                                     Style="{StaticResource NumericTextBoxStyle}" HorizontalAlignment="Right" FontSize="14" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="4" Text="{DynamicResource S.Settings.AtkDefRows}" Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" Margin="0,0,0,6" />
                            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding AtkDefRows, UpdateSourceTrigger=PropertyChanged, Delay=500}"
                                     helpers:InputHelper.IsNumericInput="True"
                                     helpers:InputHelper.NumericMax="100"
                                     helpers:InputHelper.NumericMin="1"
                                     PreviewKeyDown="AtkDefRows_PreviewKeyDown"
                                     TextChanged="RowsTextBox_TextChanged"
                                     Style="{StaticResource NumericTextBoxStyle}" HorizontalAlignment="Right" FontSize="14" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="5" Text="{DynamicResource S.Settings.DefaultToggleKey}" Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
                            <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding DefaultToggleStateKey, Mode=TwoWay, Converter={StaticResource KeyToStringConverter}}"
                                     PreviewKeyDown="DefaultToggleKey_PreviewKeyDown"
                                     Style="{StaticResource KeyTextBoxStyle}" HorizontalAlignment="Right" FontSize="14"/>

                        </Grid>
                    </GroupBox>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <GroupBox Grid.Column="0" Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,20">
                        <GroupBox.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="pack://application:,,,/Fonts/#lucide" Text="&#xE426;" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource S.Settings.SystemTray}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            </StackPanel>
                        </GroupBox.Header>
                        <StackPanel Margin="10">
                            <CheckBox x:Name="CbDisableSystray" Margin="0,6,0,6" Content="{DynamicResource S.Settings.DisableSystray}" IsChecked="{Binding DisableSystray}" Foreground="{DynamicResource AppTextBrush}"/>
                            <CheckBox Content="{DynamicResource S.Settings.MinimizeToSystray}" IsChecked="{Binding MinimizeToSystray}" Foreground="{DynamicResource AppTextBrush}" Margin="0,6,0,6">
                                <CheckBox.Style>
                                    <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DisableSystray}" Value="True">
                                                <Setter Property="IsEnabled" Value="False"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </CheckBox.Style>
                            </CheckBox>
                            <CheckBox Content="{DynamicResource S.Settings.CloseToSystray}" IsChecked="{Binding CloseToSystray}" Foreground="{DynamicResource AppTextBrush}" Margin="0,6,0,6">
                                <CheckBox.Style>
                                    <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DisableSystray}" Value="True">
                                                <Setter Property="IsEnabled" Value="False"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </CheckBox.Style>
                            </CheckBox>
                        </StackPanel>
                        </GroupBox>

                        <GroupBox Grid.Column="2" Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,20">
                            <GroupBox.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="pack://application:,,,/Fonts/#lucide" Text="&#xE154;" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{DynamicResource S.Settings.Advanced}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </GroupBox.Header>
                            <StackPanel Margin="10">
                                <CheckBox Content="{DynamicResource S.Settings.ShowExpPerHour}" IsChecked="{Binding ShowExpPerHour}" Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,6"/>
                                <CheckBox IsChecked="{Binding KeepDeadClientInfo}" Foreground="{DynamicResource AppTextBrush}" Margin="0,6,0,6">
                                    <CheckBox.Content>
                                        <TextBlock Text="{DynamicResource S.Settings.HideDeadClientInfo}" TextWrapping="Wrap" MaxWidth="250"/>
                                    </CheckBox.Content>
                                </CheckBox>
                            </StackPanel>
                        </GroupBox>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- Behavior -->
        <TabItem Style="{StaticResource SidebarTabItemStyle}">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="pack://application:,,,/Fonts/#lucide" Text="&#xE0E8;" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource S.Settings.BehaviorTab}" FontSize="14" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </StackPanel>
            </TabItem.Header>
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="20">
                <StackPanel>
                    <GroupBox Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,20">
                        <GroupBox.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="pack://application:,,,/Fonts/#lucide" Text="&#xE0E8;" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource S.Settings.GeneralBehavior}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            </StackPanel>
                        </GroupBox.Header>
                        <StackPanel Margin="10">
                            <CheckBox Margin="0,0,0,12" Content="{DynamicResource S.Settings.PauseWhenChatting}" IsChecked="{Binding PauseWhenChatting}" Foreground="{DynamicResource AppTextBrush}"/>
                            <CheckBox Margin="0,0,0,0" Content="{DynamicResource S.Settings.PauseWhenDead}" IsChecked="{Binding PauseWhenDead}" Foreground="{DynamicResource AppTextBrush}"/>
                        </StackPanel>
                    </GroupBox>


                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- Status Logger -->
        <TabItem Style="{StaticResource SidebarTabItemStyle}">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="pack://application:,,,/Fonts/#lucide" Text="&#xE284;" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource S.Settings.StatusLogger}" FontSize="14" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </StackPanel>
            </TabItem.Header>
            <views:StatusLoggerView DataContext="{Binding DataContext.StatusLogger, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,15,0,0"/>
        </TabItem>

        <!-- Developer -->
        <TabItem Style="{StaticResource SidebarTabItemStyle}">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="pack://application:,,,/Fonts/#lucide" Text="&#xE181;" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Developer" FontSize="14" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </StackPanel>
            </TabItem.Header>
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="20">
                <StackPanel>
                    <GroupBox Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,20">
                        <GroupBox.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="pack://application:,,,/Fonts/#lucide" Text="&#xE181;" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource S.Settings.DeveloperTools}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            </StackPanel>
                        </GroupBox.Header>
                        <StackPanel Margin="10">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <CheckBox Content="Debug Mode" IsChecked="{Binding DebugMode}" Foreground="{DynamicResource AppTextBrush}" Margin="0,0,20,0"/>
                                <CheckBox Content="Debug View" IsChecked="{Binding DebugView}" Foreground="{DynamicResource AppTextBrush}" IsEnabled="{Binding DebugMode}" Margin="0,0,20,0"/>
                                <CheckBox Content="{DynamicResource S.Settings.ClientLog}" IsChecked="{Binding DebugClientLog}" Foreground="{DynamicResource AppTextBrush}" IsEnabled="{Binding DebugMode}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12" IsEnabled="{Binding DebugMode}">
                                <TextBlock Text="{DynamicResource S.Settings.DebugViewHeight}" VerticalAlignment="Center" Foreground="{DynamicResource AppTextBrush}" Margin="0,0,10,0"/>
                                <TextBox Text="{Binding DebugViewHeight, UpdateSourceTrigger=PropertyChanged}" Width="50" Style="{StaticResource NumericTextBoxStyle}" helpers:InputHelper.IsNumericInput="True" helpers:InputHelper.NumericMax="1200" helpers:InputHelper.NumericMin="10" />
                            </StackPanel>
                            <CheckBox Content="{DynamicResource S.Settings.AllowResizingWindow}" IsChecked="{Binding AllowResizingWindow}" Foreground="{DynamicResource AppTextBrush}"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

    </TabControl>
</UserControl>
