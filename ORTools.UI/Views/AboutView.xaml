<UserControl x:Class="ORTools.UI.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:controls="clr-namespace:ORTools.UI.Views.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="400">
    <Grid>
        <!-- Background Toasters Effect -->
        <controls:Toasters x:Name="ToastersBackground" MinOpacity="0.3" MaxOpacity="0.8" MaxProps="40" />

        <!-- Content Overlay -->
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="12">
            <Border Background="{DynamicResource AppSurfaceAltBrush}" Opacity="0.9" CornerRadius="4"/>
            <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="20">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="{Binding BaseAppTitle}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource AppTextBrush}" HorizontalAlignment="Center" Margin="0,0,0,24"/>
                
                <TextBlock Text="{DynamicResource S.About.Desc}" 
                           TextWrapping="Wrap" TextAlignment="Center" Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,10" MaxWidth="350"/>
                           
                <TextBlock Text="{DynamicResource S.About.BuiltWith}" 
                           TextWrapping="Wrap" TextAlignment="Center" Foreground="{DynamicResource AppSubtleBrush}" MaxWidth="350"/>
                           
                <TextBlock TextAlignment="Center" Margin="0,20,0,0">
                    <Hyperlink NavigateUri="https://github.com/torrq/ORTools" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource AppLinkBrush}" TextDecorations="None">
                        <Run Text="{DynamicResource S.About.GitHub}"/>
                    </Hyperlink>
                    <Run Text=" • " Foreground="{DynamicResource AppSubtleBrush}"/>
                    <Hyperlink NavigateUri="https://github.com/torrq/ORTools/wiki" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource AppLinkBrush}" TextDecorations="None">
                        <Run Text="{DynamicResource S.About.Wiki}"/>
                    </Hyperlink>
                </TextBlock>
                    <Image Height="30" Source="/Assets/Icons/UI/torq.png" Stretch="Fill" Width="48" Margin="0,20,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
