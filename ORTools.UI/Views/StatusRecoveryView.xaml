<UserControl x:Class="ORTools.UI.Views.StatusRecoveryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ORTools.UI.ViewModels"
             Background="Transparent">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="KEY" Foreground="{StaticResource AppSubtleBrush}" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="STATUS RECOVERY TYPE" Foreground="{StaticResource AppSubtleBrush}" FontWeight="SemiBold" FontSize="11" Margin="12,0,0,0" VerticalAlignment="Center"/>
        </Grid>

        <!-- Items -->
        <ItemsControl Grid.Row="1" ItemsSource="{Binding Items}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Text="{Binding Key, Mode=TwoWay}"
                                 PreviewKeyDown="KeyTextBox_PreviewKeyDown"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                 Width="40" Height="24" MaxLength="10"
                                 Background="{StaticResource AppInputBrush}" 
                                 BorderBrush="{StaticResource AppInputBorderBrush}" 
                                 TextAlignment="Center"
                                 IsReadOnly="True" Cursor="Hand">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Key}" Value="None">
                                            <Setter Property="Foreground" Value="{StaticResource AppSubtleBrush}" />
                                            <Setter Property="FontWeight" Value="Normal" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <TextBlock Grid.Column="1" Text="{Binding DisplayName}" 
                                   Foreground="{StaticResource AppTextBrush}"
                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Settings -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,16,0,0">
            <TextBlock Text="Delay (ms):" Foreground="{StaticResource AppSubtleBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox Text="{Binding Delay, UpdateSourceTrigger=PropertyChanged}" 
                     PreviewKeyDown="DelayTextBox_PreviewKeyDown"
                     PreviewTextInput="DelayTextBox_PreviewTextInput"
                     Width="60" Height="24" 
                     Background="{StaticResource AppInputBrush}" 
                     Foreground="{StaticResource AppTextBrush}" 
                     BorderBrush="{StaticResource AppInputBorderBrush}" 
                     TextAlignment="Center" VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
