<UserControl x:Class="ORTools.UI.Views.AutopotView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ORTools.UI.Views"
             Background="Transparent">
    <Grid Margin="12,12,12,16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <GroupBox Foreground="{DynamicResource AppTextBrush}" Background="Transparent" BorderBrush="{DynamicResource AppBorderBrush}" Padding="0,8,0,0">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="pack://application:,,,/Icons/tab_autopot_hp.png" Width="10" Height="12" Stretch="None" Margin="0,0,6,0" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    <TextBlock Text="Autopot HP" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
            </GroupBox.Header>
            <views:AutopotHPView DataContext="{Binding AutopotHP}" />
        </GroupBox>

        <GroupBox Grid.Column="2" Foreground="{DynamicResource AppTextBrush}" Background="Transparent" BorderBrush="{DynamicResource AppBorderBrush}" Padding="0,8,0,0">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="pack://application:,,,/Icons/tab_autopot_sp.png" Width="10" Height="12" Stretch="None" Margin="0,0,6,0" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    <TextBlock Text="Autopot SP" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
            </GroupBox.Header>
            <views:AutopotSPView DataContext="{Binding AutopotSP}" />
        </GroupBox>
    </Grid>
</UserControl>
