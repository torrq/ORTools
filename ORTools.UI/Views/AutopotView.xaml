<UserControl x:Class="ORTools.UI.Views.AutopotView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ORTools.UI.Views"
             Background="Transparent">
    <Grid Margin="12,12,12,16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <GroupBox Header="Autopot HP" Foreground="{DynamicResource AppTextBrush}" Background="Transparent" BorderBrush="{DynamicResource AppBorderBrush}" Padding="0,8,0,0">
            <views:AutopotHPView DataContext="{Binding AutopotHP}" />
        </GroupBox>

        <GroupBox Header="Autopot SP" Grid.Column="2" Foreground="{DynamicResource AppTextBrush}" Background="Transparent" BorderBrush="{DynamicResource AppBorderBrush}" Padding="0,8,0,0">
            <views:AutopotSPView DataContext="{Binding AutopotSP}" />
        </GroupBox>
    </Grid>
</UserControl>
