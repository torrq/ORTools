<UserControl x:Class="ORTools.UI.Views.DebuffsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ORTools.UI.ViewModels" xmlns:helpers="clr-namespace:ORTools.UI.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             Background="Transparent">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Status Recovery Row -->
        <ItemsControl ItemsSource="{Binding StatusRecoveryItems}" HorizontalAlignment="Center">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="10,0,10,0">
                        <!-- Icon -->
                        <Image Source="{Binding ImagePath}" Stretch="None" Margin="0,0,8,0" VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="NearestNeighbor" SnapsToDevicePixels="True"/>
                        
                        <!-- Name -->
                        <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" 
                                   Foreground="{StaticResource AppTextBrush}" FontSize="14" Margin="0,0,8,0"/>

                        <!-- Key -->
                        <TextBox Text="{Binding Key, Mode=TwoWay}"
                                 PreviewKeyDown="KeyTextBox_PreviewKeyDown"
                                 Width="60" Height="28" MaxLength="10" FontSize="14"
                                 Background="{StaticResource AppInputBrush}" 
                                 BorderBrush="{StaticResource AppInputBorderBrush}" 
                                 TextAlignment="Center" VerticalAlignment="Center"
                                 IsReadOnly="True" Cursor="Hand">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Key}" Value="None">
                                            <Setter Property="Foreground" Value="{StaticResource AppSubtleBrush}" />
                                            <Setter Property="FontWeight" Value="Normal" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Separator -->
        <Border Grid.Row="1" Height="1" Background="{StaticResource AppBorderBrush}" Margin="0,16"/>

        <!-- Debuffs Grid -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding DebuffItems}" HorizontalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" ItemWidth="240" ItemHeight="48" Margin="0,10,0,0" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="10,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="65"/>
                            </Grid.ColumnDefinitions>

                            <Image Source="{Binding ImagePath}" Stretch="None" VerticalAlignment="Center" Margin="0,0,8,0"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor" SnapsToDevicePixels="True"/>

                            <TextBlock Grid.Column="1" Text="{Binding DisplayName}" VerticalAlignment="Center"
                                       Foreground="{StaticResource AppTextBrush}" FontSize="14" TextTrimming="CharacterEllipsis" Margin="0,0,8,0"/>

                            <TextBox Grid.Column="2" Text="{Binding Key, Mode=TwoWay}"
                                     PreviewKeyDown="KeyTextBox_PreviewKeyDown"
                                     Width="60" Height="28" MaxLength="10" FontSize="14"
                                     Background="{StaticResource AppInputBrush}" 
                                     BorderBrush="{StaticResource AppInputBorderBrush}" 
                                     TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Right"
                                     IsReadOnly="True" Cursor="Hand">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
                                        <Setter Property="FontWeight" Value="Bold" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Key}" Value="None">
                                                <Setter Property="Foreground" Value="{StaticResource AppSubtleBrush}" />
                                                <Setter Property="FontWeight" Value="Normal" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Settings -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,16,0,0" HorizontalAlignment="Right">
            <TextBlock Text="Delay (ms):" FontSize="14" Foreground="{StaticResource AppSubtleBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox Text="{Binding Delay, UpdateSourceTrigger=PropertyChanged, Delay=500}" 
                     helpers:InputHelper.IsNumericInput="True"
                     
                     Width="70" Height="28" FontSize="14"
                     Background="{StaticResource AppInputBrush}" 
                     Foreground="{StaticResource AppTextBrush}" 
                     BorderBrush="{StaticResource AppInputBorderBrush}" 
                     TextAlignment="Center" VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
