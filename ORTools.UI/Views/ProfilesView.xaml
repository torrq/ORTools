<UserControl x:Class="ORTools.UI.Views.ProfilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ORTools.UI.ViewModels" xmlns:helpers="clr-namespace:ORTools.UI.Helpers"
             Background="Transparent">
    
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        
        <!-- Profiles List -->
        <ListBox Grid.Column="0" ItemsSource="{Binding ProfileList}" SelectedItem="{Binding SelectedProfile}"
                 Background="{StaticResource AppInputBrush}" Foreground="{StaticResource AppTextBrush}"
                 BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1"
                 HorizontalContentAlignment="Stretch" Margin="0,0,16,0">
            <ListBox.Resources>
                <!-- Override default selection colors -->
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3A3A3A" />
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#E0E0E0" />
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#3A3A3A" />
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#E0E0E0" />
            </ListBox.Resources>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <EventSetter Event="MouseDoubleClick" Handler="ListBoxItem_MouseDoubleClick" />
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border x:Name="ItemBorder" BorderThickness="3,0,0,0" BorderBrush="Transparent" Padding="8,4" Background="Transparent">
                        <!-- Name of profile -->
                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
                                    <Setter Property="FontStyle" Value="Normal" />
                                    <Setter Property="FontWeight" Value="Normal" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Name}" Value="Default">
                                            <Setter Property="FontStyle" Value="Italic" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#4CAF50" /> <!-- Green left border indicator -->
                            <Setter TargetName="ItemBorder" Property="Background" Value="#1A4CAF50" /> <!-- Faint green background -->
                        </DataTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="#33FFFFFF" />
                        </Trigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Buttons Panel -->
        <StackPanel Grid.Column="1" Width="140">
            <Button Content="Create Profile" Command="{Binding SaveProfileCommand}" Height="30" Margin="0,0,0,10"
                    Style="{StaticResource SecondaryButtonStyle}" />
            
            <Button Content="Rename Profile" Command="{Binding RenameProfileCommand}" Height="30" Margin="0,0,0,10"
                    Style="{StaticResource SecondaryButtonStyle}" />

            <Button Content="Copy Profile" Command="{Binding CopyProfileCommand}" Height="30" Margin="0,0,0,10"
                    Style="{StaticResource SecondaryButtonStyle}" />
            
            <Button Content="Delete Profile" Command="{Binding RemoveProfileCommand}" Height="30" Margin="0,0,0,10"
                    Style="{StaticResource DangerButtonStyle}" />
        </StackPanel>
    </Grid>
</UserControl>
