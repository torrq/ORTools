<UserControl x:Class="ORTools.UI.Views.AutopotSPView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ORTools.UI.ViewModels" xmlns:helpers="clr-namespace:ORTools.UI.Helpers"
             Background="Transparent">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="ON" Foreground="{StaticResource AppSubtleBrush}" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="KEY" Foreground="{StaticResource AppSubtleBrush}" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="2" Text="SP PERCENT THRESHOLD" Foreground="{StaticResource AppSubtleBrush}" FontWeight="SemiBold" FontSize="11" Margin="12,0,0,0" VerticalAlignment="Center"/>
        </Grid>

        <!-- Slots -->
        <ItemsControl Grid.Row="1" ItemsSource="{Binding Slots}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox IsChecked="{Binding Enabled}" 
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center"/>

                        <TextBox Grid.Column="1" Text="{Binding Key, Mode=TwoWay}"
                                 PreviewKeyDown="KeyTextBox_PreviewKeyDown"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                 Width="40" Height="24" MaxLength="10"
                                 Background="{StaticResource AppInputBrush}" 
                                 BorderBrush="{StaticResource AppInputBorderBrush}" 
                                 TextAlignment="Center"
                                 IsReadOnly="True" Cursor="Hand">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Key}" Value="None">
                                            <Setter Property="Foreground" Value="{StaticResource AppSubtleBrush}" />
                                            <Setter Property="FontWeight" Value="Normal" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <Slider Grid.Column="2" Value="{Binding Percent, Delay=150}" Minimum="0" Maximum="100"
                                VerticalAlignment="Center" Margin="12,0,12,0"
                                IsSnapToTickEnabled="True" TickFrequency="1" />

                        <TextBox Grid.Column="3" Text="{Binding Percent, UpdateSourceTrigger=PropertyChanged, Delay=500}" 
                                 Foreground="{StaticResource AppTextBrush}" Background="{StaticResource AppInputBrush}"
                                 BorderBrush="{StaticResource AppInputBorderBrush}" TextAlignment="Center" Width="36"
                                 VerticalAlignment="Center" HorizontalAlignment="Right"
                                  
                                  />
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Settings -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,16,0,0">
            <TextBlock Text="Delay (ms):" Foreground="{StaticResource AppSubtleBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox Text="{Binding Delay, UpdateSourceTrigger=PropertyChanged, Delay=500}" 
                     helpers:InputHelper.IsNumericInput="True"
                     
                     
                     Width="60" Height="24" 
                     Background="{StaticResource AppInputBrush}" 
                     Foreground="{StaticResource AppTextBrush}" 
                     BorderBrush="{StaticResource AppInputBorderBrush}" 
                     TextAlignment="Center" VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
