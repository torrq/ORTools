<UserControl x:Class="ORTools.UI.Views.AutopotSPView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ORTools.UI.ViewModels" xmlns:helpers="clr-namespace:ORTools.UI.Helpers"
             Background="Transparent">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="36"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="ON" Foreground="{StaticResource AppSubtleBrush}" FontWeight="SemiBold" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="KEY" Foreground="{StaticResource AppSubtleBrush}" FontWeight="SemiBold" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="2" Text="SP %" Foreground="{StaticResource AppSubtleBrush}" FontWeight="SemiBold" FontSize="10" Margin="8,0,0,0" VerticalAlignment="Center"/>
        </Grid>

        <!-- Slots -->
        <ItemsControl Grid.Row="1" ItemsSource="{Binding Slots}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox IsChecked="{Binding Enabled}" 
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center">
                            <CheckBox.LayoutTransform>
                                <ScaleTransform ScaleX="0.8" ScaleY="0.8" />
                            </CheckBox.LayoutTransform>
                        </CheckBox>

                        <TextBox Grid.Column="1" Text="{Binding Key, Mode=TwoWay, Converter={StaticResource KeyToStringConverter}}"
                                 PreviewKeyDown="KeyTextBox_PreviewKeyDown"
                                 Style="{StaticResource KeyTextBoxStyle}" HorizontalAlignment="Center" Width="40" Height="22" />

                        <Slider Grid.Column="2" Value="{Binding Percent, Delay=150}" Minimum="0" Maximum="100"
                                VerticalAlignment="Center" Margin="8,0,8,0"
                                IsSnapToTickEnabled="True" TickFrequency="1" />

                        <TextBox Grid.Column="3" Text="{Binding Percent, UpdateSourceTrigger=PropertyChanged, Delay=500}" 
                                 Style="{StaticResource NumericTextBoxStyle}" Width="32" Height="22" FontSize="11"
                                 VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Settings -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,16,0,0" HorizontalAlignment="Center">
            <TextBlock Text="Delay (ms):" Foreground="{StaticResource AppSubtleBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox Text="{Binding Delay, UpdateSourceTrigger=PropertyChanged, Delay=500}" 
                     helpers:InputHelper.IsNumericInput="True"
                     Style="{StaticResource NumericTextBoxStyle}" />
        </StackPanel>
    </Grid>
</UserControl>
