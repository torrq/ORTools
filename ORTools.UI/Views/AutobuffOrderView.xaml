<UserControl x:Class="ORTools.UI.Views.AutobuffOrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewmodels="clr-namespace:ORTools.UI.ViewModels"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=viewmodels:AutobuffOrderViewModel}">
    <Grid Margin="16,0,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Margin="0,0,0,8" Foreground="{DynamicResource AppTextBrush}" TextWrapping="Wrap" FontSize="13" HorizontalAlignment="Center" Text="Active Autobuff Skills and Items are executed in the order shown below (top-to-bottom)"/>

        <ListBox Grid.Row="1" ItemsSource="{Binding ActiveItems}" 
                 Background="{DynamicResource AppSurfaceBrush}" 
                 BorderBrush="{DynamicResource AppBorderBrush}" 
                 Foreground="{DynamicResource AppTextBrush}" 
                 HorizontalContentAlignment="Stretch"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="4,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        <Button Grid.Column="0" Content="✕" Margin="0,0,12,0" Width="24" Height="24" Padding="0"
                                Style="{StaticResource DangerButtonStyle}"
                                ToolTip="Unset Hotkey"
                                Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" 
                                CommandParameter="{Binding}" VerticalAlignment="Center" />

                        <Border Grid.Column="1" Background="{DynamicResource AppSurfaceBrush}" 
                                BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" 
                                CornerRadius="4" MinWidth="26" Height="24" Padding="6,0" Margin="0,0,12,0"
                                VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding DisplayKey}" Foreground="{DynamicResource AppTextBrush}" 
                                       FontSize="11" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Border>

                        <Border Grid.Column="2" Width="24" Height="24" Background="Transparent" CornerRadius="2" Margin="0,0,12,0" VerticalAlignment="Center">
                            <!-- Fallback for image load failure isn't built into standard WPF Image easily, so we just let it be blank if not found -->
                            <Image Source="{Binding IconPath}" Stretch="None"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor" SnapsToDevicePixels="True"/>
                        </Border>
                        
                        <TextBlock Grid.Column="3" Text="{Binding DisplayName}" VerticalAlignment="Center" FontSize="14" />
                        
                        <StackPanel Grid.Column="4" Orientation="Horizontal">
                            <Button Content="↑" Margin="0,0,4,0" Width="28" Height="28" Padding="0"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" 
                                    CommandParameter="{Binding}" />
                            <Button Content="↓" Width="28" Height="28" Padding="0"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" 
                                    CommandParameter="{Binding}" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
