<Window x:Class="ORTools.UI.Views.Dialogs.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Input" Height="180" Width="350"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource AppBaseBrush}"
        WindowStyle="ToolWindow"
        Topmost="True">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="MessageTextBlock" Text="Enter text:" Foreground="{DynamicResource AppTextBrush}" FontSize="14" TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,0,8" />

        <TextBox x:Name="InputTextBox" Grid.Row="1" Height="28" FontSize="14"
                 Background="{DynamicResource AppInputBrush}" 
                 Foreground="{DynamicResource AppTextBrush}" 
                 BorderBrush="{DynamicResource AppInputBorderBrush}" 
                 VerticalContentAlignment="Center" Padding="4,0" Margin="0,0,0,16" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="OkButton" Content="OK" Width="70" Height="28" Margin="0,0,8,0"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="OkButton_Click" IsDefault="True"/>
            <Button x:Name="CancelButton" Content="Cancel" Width="70" Height="28"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="CancelButton_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
