<Window x:Class="ORTools.UI.Views.Dialogs.ConfirmDeleteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm Delete" Height="150" Width="350"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource AppBaseBrush}"
        WindowStyle="ToolWindow"
        Topmost="True">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="MessageTextBlock" Text="Are you sure you want to delete this?" Foreground="{StaticResource AppTextBrush}" FontSize="14" TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,0,16" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="YesButton" Content="Yes" Width="70" Height="28" Margin="0,0,8,0"
                    Style="{StaticResource DangerButtonStyle}"
                    Click="YesButton_Click" IsDefault="True"/>
            <Button x:Name="NoButton" Content="No" Width="70" Height="28"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="NoButton_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
