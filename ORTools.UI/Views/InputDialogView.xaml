<UserControl x:Class="ORTools.UI.Views.InputDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:ORTools.UI.Helpers"
             Background="Transparent"
             FocusManager.FocusedElement="{Binding ElementName=InputTextBox}">
    
    <Border Background="{DynamicResource AppSurfaceBrush}" 
            BorderBrush="{DynamicResource AppBorderBrush}" 
            BorderThickness="1" 
            CornerRadius="8" 
            Padding="24"
            HorizontalAlignment="Center" 
            VerticalAlignment="Center">
        
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" Opacity="0.5" Direction="270" ShadowDepth="5"/>
        </Border.Effect>

        <StackPanel MinWidth="250">
            <TextBlock Text="{Binding TitleText}" Foreground="{DynamicResource AppTextBrush}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16" HorizontalAlignment="Center"/>
            
            <TextBlock Text="{Binding MessageText}" Foreground="{DynamicResource AppSubtleBrush}" FontSize="14" Margin="0,0,0,8" TextWrapping="Wrap" MaxWidth="350"/>
            
            <TextBox x:Name="InputTextBox"
                     Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}" 
                     Loaded="InputTextBox_Loaded"
                     Margin="0,0,0,24" Height="28" FontSize="14" Width="250"
                     Style="{StaticResource NumericTextBoxStyle}"
                     HorizontalContentAlignment="Left" Padding="4,0" />
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="{DynamicResource S.Dialog.Cancel}" Command="{Binding CancelCommand}" 
                        IsCancel="True"
                        Style="{StaticResource SecondaryButtonStyle}" 
                        Width="100" Height="32" Margin="0,0,16,0"
                        Foreground="{DynamicResource AppSubtleBrush}"
                        Background="Transparent"/>
                
                <Button Content="{DynamicResource S.Dialog.Confirm}" Command="{Binding SaveCommand}" 
                        IsDefault="True"
                        Style="{StaticResource PrimaryButtonStyle}" 
                        Width="100" Height="32"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
